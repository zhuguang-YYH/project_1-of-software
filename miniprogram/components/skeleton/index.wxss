@keyframes skeleton-shimmer {
  0% { background-position: -240rpx 0; }
  100% { background-position: 240rpx 0; }
}

.skeleton-wrap {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx 80rpx;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
}

.skeleton-title {
  margin: 12rpx 4rpx 28rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.skeleton-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.08);
}

.skeleton-cover,
.skeleton-rank,
.skeleton-line,
.skeleton-pill {
  border-radius: 10rpx;
  background: linear-gradient(90deg, #eef0ff 0%, #f7f8fd 50%, #eef0ff 100%);
  background-size: 480rpx 100%;
  animation: skeleton-shimmer 1.4s ease-in-out infinite;
}

.skeleton-cover {
  width: 152rpx;
  min-width: 152rpx;
  height: 188rpx;
  border-radius: 14rpx;
}

.skeleton-rank {
  width: 76rpx;
  min-width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  align-self: center;
}

.skeleton-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
}

.skeleton-line {
  height: 24rpx;
}

.line-title {
  width: 78%;
  height: 30rpx;
}

.line-short {
  width: 46%;
}

.line-mid {
  width: 62%;
}

.skeleton-pill {
  width: 112rpx;
  min-width: 112rpx;
  height: 44rpx;
  border-radius: 999rpx;
  align-self: flex-start;
}

.variant-card .skeleton-row {
  min-height: 172rpx;
}

.variant-ranking .skeleton-row {
  align-items: center;
}

.variant-ranking .skeleton-pill {
  display: none;
}

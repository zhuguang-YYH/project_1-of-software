.detective-item {
  position: relative;
  min-height: 92rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #ffffff;
  overflow: hidden;
}

.detective-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 18rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: #d7e4f2;
}

.detective-item:active {
  background: #f8fafc;
}

.variant-compact {
  min-height: 82rpx;
  padding: 16rpx 18rpx;
}

.rank-mark {
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2477c3, #4aa3df);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 16rpx rgba(36, 119, 195, 0.18);
}

.avatar-wrap {
  position: relative;
  flex: 0 0 auto;
  width: 72rpx;
  height: 72rpx;
}

.avatar {
  position: relative;
  z-index: 2;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #edf2f7;
  border: 3rpx solid #ffffff;
  box-shadow: 0 6rpx 14rpx rgba(15, 23, 42, 0.12);
}

.rank-glow {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: rgba(245, 158, 11, 0.2);
}

.main {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  display: block;
  margin-top: 6rpx;
  color: #8a96a8;
  font-size: 22rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score {
  flex: 0 0 auto;
  min-width: 86rpx;
  text-align: right;
}

.score-value,
.score-label {
  display: block;
}

.score-value {
  color: #c47a12;
  font-size: 30rpx;
  line-height: 1.1;
  font-weight: 900;
}

.score-label {
  margin-top: 4rpx;
  color: #a3adba;
  font-size: 20rpx;
}

.arrow {
  flex: 0 0 auto;
  color: #c0c8d2;
  font-size: 34rpx;
}

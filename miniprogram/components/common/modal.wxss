.modal-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  z-index: 1000;
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  padding: 40rpx 40rpx 0;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #333;
}

.modal-body {
  min-height: 80rpx;
  padding: 28rpx 40rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
}

.modal-footer {
  display: flex;
  min-height: 88rpx;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  padding: 0;
  box-sizing: border-box;
  border: none;
  border-radius: 0;
  background: #fff;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.modal-btn::after {
  border: none;
}

.cancel-btn {
  border-right: 1rpx solid #eee;
}

.confirm-btn {
  color: #5b6cff;
  font-weight: 700;
}

.theme-gold .modal-mask {
  background-color: rgba(0, 0, 0, 0.68);
}

.theme-gold .modal-content {
  background: #151515;
  border: 1rpx solid rgba(212, 175, 55, 0.24);
  box-shadow: 0 28rpx 68rpx rgba(0, 0, 0, 0.42);
}

.theme-gold .modal-header,
.theme-gold .modal-footer {
  border-color: rgba(212, 175, 55, 0.18);
}

.theme-gold .modal-title {
  color: #f4ecd6;
}

.theme-gold .modal-text {
  color: rgba(244, 236, 214, 0.78);
}

.theme-gold .modal-btn {
  background: #151515;
}

.theme-gold .cancel-btn {
  color: rgba(244, 236, 214, 0.76);
  border-right-color: rgba(212, 175, 55, 0.18);
}

.theme-gold .confirm-btn {
  color: #17110a !important;
  border-color: rgba(212, 175, 55, 0.6) !important;
  background: linear-gradient(135deg, #f8e7a8 0%, #d4af37 54%, #b98d1d 100%);
  font-weight: 800;
}

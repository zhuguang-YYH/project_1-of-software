/**
 * 全局应用样式
 * 导入通用样式库，重置基础样式
 */

@import 'styles/common.wxss';

/* 全局重置 */
view, text, image, button, input, textarea, select, picker {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

page {
  background-color: #0a0a0a;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 按钮重置 */
button {
  background: initial;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
}

button[class] {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
  line-height: 1.2 !important;
}

button text {
  line-height: 1.2;
  text-align: center;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

button::before {
  display: none;
}

/* 输入框重置 */
input {
  background: transparent;
}

input:focus {
  outline: 0;
}

/* 文本重置 */
textarea {
  background: transparent;
}

textarea:focus {
  outline: 0;
}

/* 图片自适应 */
image {
  max-width: 100%;
  height: auto;
}

/* 容器基础样式 */
.container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.page-wrapper {
  flex: 1;
}

/* 避免过长的文本换行过度 */
view, text {
  word-break: break-all;
  word-wrap: break-word;
  white-space: pre-wrap;
}

/* 滚动容器样式 */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-thumb {
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 4px;
}

::-webkit-scrollbar-track {
  background-color: transparent;
}


page {
  background: #f6f6f6;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

/* 主题可读性与系统大字体适配 */
.theme-blue {
  color: #1a1f3a;
}

.theme-gold {
  color: #f4ecd6;
}

.theme-gold input,
.theme-gold textarea {
  caret-color: #d4af37;
}

.theme-gold input::placeholder,
.theme-gold textarea::placeholder {
  color: rgba(244, 236, 214, 0.48);
}

.theme-gold button[disabled],
.theme-blue button[disabled] {
  opacity: 0.58;
}


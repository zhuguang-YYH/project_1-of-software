<view class="container page-bg-gradient theme-{{theme}}" wx:if="{{!loading}}">
  <view class="error-state" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>

  <view class="tab-container" wx:else>
    <view class="tabs">
      <view class="tab-item {{tab === 'top3' ? 'active' : ''}}" data-tab="top3" bindtap="switchTab">前三名</view>
      <view class="tab-item {{tab === 'full' ? 'active' : ''}}" data-tab="full" bindtap="switchTab">完整榜单</view>
      <view class="tab-item {{tab === 'my' ? 'active' : ''}}" data-tab="my" bindtap="switchTab">我的排名</view>
    </view>

    <view class="tab-content" wx:if="{{tab === 'top3'}}">
      <view class="podium-wrap" wx:if="{{top_three.length > 0}}">
        <image class="podium-decor" src="/images/rank_card/排行榜背景装饰.svg" mode="aspectFit" />
        <view class="podium">
          <view class="podium-item rank-2 tap-feedback" wx:if="{{top_three[1]}}" data-user_id="{{top_three[1].user_id}}" bindtap="openDetectiveCard">
            <image class="podium-medal medal-silver" src="/images/rank_card/第二名奖牌.svg" mode="aspectFit" />
            <image class="podium-avatar avatar-silver" src="{{top_three[1].avatar_url || '/images/icons/avatar.png'}}" mode="aspectFill" />
            <text class="podium-name">{{top_three[1].nickname}}</text>
            <text class="podium-points">{{top_three[1].total_points}} 分</text>
            <view class="podium-base base-silver"><text>2nd</text></view>
          </view>

          <view class="podium-item rank-1 tap-feedback" wx:if="{{top_three[0]}}" data-user_id="{{top_three[0].user_id}}" bindtap="openDetectiveCard">
            <image class="podium-medal medal-gold" src="/images/rank_card/第一名奖牌.svg" mode="aspectFit" />
            <image class="podium-avatar avatar-gold" src="{{top_three[0].avatar_url || '/images/icons/avatar.png'}}" mode="aspectFill" />
            <text class="podium-name">{{top_three[0].nickname}}</text>
            <text class="podium-points">{{top_three[0].total_points}} 分</text>
            <view class="podium-base base-gold"><text>1st</text></view>
          </view>

          <view class="podium-item rank-3 tap-feedback" wx:if="{{top_three[2]}}" data-user_id="{{top_three[2].user_id}}" bindtap="openDetectiveCard">
            <image class="podium-medal medal-bronze" src="/images/rank_card/第三名奖牌.svg" mode="aspectFit" />
            <image class="podium-avatar avatar-bronze" src="{{top_three[2].avatar_url || '/images/icons/avatar.png'}}" mode="aspectFill" />
            <text class="podium-name">{{top_three[2].nickname}}</text>
            <text class="podium-points">{{top_three[2].total_points}} 分</text>
            <view class="podium-base base-bronze"><text>3rd</text></view>
          </view>
        </view>
        <view class="podium-tip">点击头像查看侦探名片</view>
      </view>

      <view class="empty-state" wx:else>
        <text class="empty-text">暂无排行数据</text>
      </view>
    </view>

    <view class="tab-content" wx:if="{{tab === 'full'}}">
      <view class="ranking-list" wx:if="{{full_ranking.length > 0}}">
        <detective-card-item
          wx:for="{{full_ranking}}"
          wx:key="user_id"
          user="{{item}}"
          theme="{{rankingCardTheme}}"
          bind:cardtap="openDetectiveCard" />
      </view>

      <view class="empty-state" wx:else>
        <text class="empty-text">暂无排行数据</text>
      </view>
    </view>

    <view class="tab-content" wx:if="{{tab === 'my'}}">
      <view class="my-ranking-card" wx:if="{{user_ranking}}">
        <view class="my-ranking-header">
          <text class="my-ranking-title">我的排名</text>
          <text class="my-ranking-sub">累计积分越高，排名越靠前</text>
        </view>
        <view class="my-ranking-content">
          <view class="my-ranking-row">
            <view class="my-stat">
              <text class="my-stat-value">{{user_ranking.rank_no || '—'}}</text>
              <text class="my-stat-label">名次</text>
            </view>
            <view class="my-stat">
              <text class="my-stat-value">{{user_ranking.total_points || 0}}</text>
              <text class="my-stat-label">总积分</text>
            </view>
          </view>
          <view class="my-ranking-item">
            <text class="my-ranking-label">昵称</text>
            <text class="my-ranking-value">{{user_ranking.nickname || '侦探'}}</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:else>
        <text class="empty-text">请先登录查看排名</text>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{show_card_modal}}" bindtap="closeCardModal">
    <view class="card-modal" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">侦探名片</text>
        <button class="modal-close" bindtap="closeCardModal">×</button>
      </view>

      <view class="card-loading" wx:if="{{card_loading}}">
        <view class="mini-spinner"></view>
        <text>加载中...</text>
      </view>

      <view class="detective-card" wx:if="{{selected_card}}">
        <view class="card-hero">
          <image class="card-hero-bg" src="/images/rank_card/侦探档案卡背景.svg" mode="aspectFill" />
          <view class="card-case-no">DETECTIVE PROFILE</view>
          <image class="card-avatar" src="{{selected_card.avatar_url || '/images/icons/avatar.png'}}" />
          <view class="card-identity">
            <text class="card-name">{{selected_card.display_name}}</text>
            <text class="card-signature">{{selected_card.self_intro}}</text>
          </view>
        </view>

        <view class="card-stats">
          <view class="card-stat">
            <image class="card-stat-icon" src="/images/rank_card/排名图标.svg" mode="aspectFit" />
            <text class="card-stat-value">{{selected_card.rank_no}}</text>
            <text class="card-stat-label">排名</text>
          </view>
          <view class="card-stat">
            <image class="card-stat-icon" src="/images/rank_card/积分图标.svg" mode="aspectFit" />
            <text class="card-stat-value">{{selected_card.total_points}}</text>
            <text class="card-stat-label">总积分</text>
          </view>
          <view class="card-stat">
            <image class="card-stat-icon" src="/images/rank_card/可兑换积分图标.svg" mode="aspectFit" />
            <text class="card-stat-value">{{selected_card.available_points}}</text>
            <text class="card-stat-label">可兑换</text>
          </view>
        </view>

        <view class="card-section" wx:if="{{selected_card.interests}}">
          <text class="card-section-title">兴趣标签</text>
          <text class="card-section-value">{{selected_card.interests}}</text>
        </view>
        <view class="card-section" wx:if="{{selected_card.created_text}}">
          <text class="card-section-title">注册时间</text>
          <text class="card-section-value">{{selected_card.created_text}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<skeleton wx:elif="{{loading}}" variant="ranking" rows="4" title="加载排行中..." />

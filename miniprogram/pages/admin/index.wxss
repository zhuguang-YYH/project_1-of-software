.page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #243041;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #64748b;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #2477c3;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.error-banner {
  margin: 24rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stats-grid {
  padding: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.stat {
  padding: 22rpx 16rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(22, 34, 51, 0.06);
}

.num {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2477c3;
}

.num.warn {
  color: #c2410c;
}

.label {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #7b8794;
}

.tab-nav {
  margin: 0 24rpx 20rpx;
  padding: 6rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6rpx;
  border-radius: 8rpx;
  background: #e8edf3;
}

.tab-item {
  min-width: 0;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.tab-item.active {
  background: #ffffff;
  color: #2477c3;
  font-weight: 700;
}

.panel {
  margin: 0 24rpx 36rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(22, 34, 51, 0.06);
}

.panel-title {
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.panel-title.compact {
  margin-bottom: 18rpx;
  font-size: 29rpx;
}

.section-divider {
  height: 1rpx;
  margin: 34rpx 0 26rpx;
  background: #edf2f7;
}

.field {
  margin-bottom: 20rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #475569;
}

.field input,
.field textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #f7f9fc;
  color: #1f2937;
  font-size: 27rpx;
}

.field input {
  height: 78rpx;
  padding: 0 20rpx;
}

.field textarea {
  min-height: 160rpx;
  padding: 18rpx 20rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.primary-btn,
.small-btn {
  border-radius: 8rpx;
  color: #ffffff;
  background: #2477c3;
}

.primary-btn {
  margin-top: 10rpx;
  height: 78rpx;
  line-height: 78rpx;
  font-size: 27rpx;
}

.small-btn {
  margin: 18rpx 0 0;
  width: 180rpx;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 24rpx;
}

.small-btn.success {
  background: #15945f;
}

.small-btn.ghost {
  color: #475569;
  background: #eef2f7;
}

.ops-card {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.ops-card:last-of-type {
  border-bottom: 0;
}

.ops-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.ops-title,
.ops-meta,
.ops-desc {
  display: block;
}

.ops-title {
  color: #243041;
  font-size: 28rpx;
  font-weight: 700;
}

.ops-meta,
.ops-desc,
.ops-line {
  color: #7b8794;
  font-size: 23rpx;
}

.ops-meta {
  margin-top: 8rpx;
}

.ops-desc {
  margin-top: 14rpx;
  line-height: 1.5;
}

.ops-line {
  margin-top: 14rpx;
  display: flex;
  gap: 24rpx;
}

.ops-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.ops-actions .small-btn {
  margin-top: 18rpx;
}

.feedback-card {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.feedback-card:last-child {
  border-bottom: 0;
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #243041;
}

.badge {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #9a3412;
  background: #ffedd5;
  font-size: 22rpx;
}

.badge.done {
  color: #166534;
  background: #dcfce7;
}

.badge.blue {
  color: #1d4ed8;
  background: #dbeafe;
}

.feedback-content {
  display: block;
  margin-top: 14rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.55;
}

.feedback-time {
  display: block;
  margin-top: 10rpx;
  color: #8a96a8;
  font-size: 22rpx;
}

.log-card {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.log-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.log-operation {
  color: #243041;
  font-size: 27rpx;
  font-weight: 700;
}

.log-time,
.log-target,
.log-admin {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  word-break: break-all;
}

.switch-row {
  min-height: 94rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #edf2f7;
}

.switch-title,
.switch-desc {
  display: block;
}

.switch-title {
  color: #243041;
  font-size: 27rpx;
  font-weight: 700;
}

.switch-desc {
  margin-top: 6rpx;
  color: #8a96a8;
  font-size: 23rpx;
}

.empty {
  padding: 64rpx 0;
  text-align: center;
  color: #8a96a8;
  font-size: 26rpx;
}

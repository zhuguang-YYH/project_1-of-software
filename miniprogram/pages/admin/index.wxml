<view class="page theme-{{theme}} {{a11yFontClass}}">
  <view class="loading-state theme-{{theme}} {{a11yFontClass}}" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载后台中...</text>
  </view>

  <scroll-view class="scroll-view" scroll-y show-scrollbar="{{false}}" refresher-enabled="{{true}}" bindrefresherrefresh="onPullDownRefresh" wx:else>
    <view class="error-banner" wx:if="{{error}}">
      <text>{{error}}</text>
      <button size="mini" bindtap="onRetry">重试</button>
    </view>

    <view class="stats-grid" wx:if="{{!error}}">
      <view class="stat"><text class="num">{{stats.user_count || 0}}</text><text class="label">用户</text></view>
      <view class="stat"><text class="num">{{stats.puzzle_count || 0}}</text><text class="label">谜题</text></view>
      <view class="stat"><text class="num">{{stats.activity_count || 0}}</text><text class="label">活动</text></view>
      <view class="stat"><text class="num">{{stats.inventory_count || 0}}</text><text class="label">物资</text></view>
      <view class="stat"><text class="num warn">{{stats.feedback_pending || 0}}</text><text class="label">待反馈</text></view>
      <view class="stat"><text class="num warn">{{stats.borrow_active || 0}}</text><text class="label">待借阅</text></view>
      <view class="stat"><text class="num warn">{{stats.exchange_pending || 0}}</text><text class="label">待兑换</text></view>
    </view>

    <view class="trend-panel" wx:if="{{!error && dashboard_trend.points.length}}">
      <view class="trend-head">
        <view>
          <text class="trend-title">运营趋势</text>
          <text class="trend-sub">近 7 天报名量、兑换量、活跃用户</text>
        </view>
        <view class="trend-legend">
          <text class="legend-item reg">报名</text>
          <text class="legend-item exchange">兑换</text>
          <text class="legend-item active">活跃</text>
        </view>
      </view>
      <view class="trend-chart">
        <view class="trend-day" wx:for="{{dashboard_trend.points}}" wx:key="date">
          <view class="bar-group">
            <view class="bar reg" style="height: {{item.registration_height}}rpx"><text>{{item.registrations}}</text></view>
            <view class="bar exchange" style="height: {{item.exchange_height}}rpx"><text>{{item.exchanges}}</text></view>
            <view class="bar active" style="height: {{item.active_height}}rpx"><text>{{item.active_users}}</text></view>
          </view>
          <text class="trend-date">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="tab-nav" wx:if="{{!error}}">
      <view class="tab-item {{tab === item.key ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="key" data-tab="{{item.key}}" bindtap="switchTab">
        {{item.label}}
      </view>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'puzzle'}}">
      <view class="panel-title">{{puzzleForm.puzzle_type === 'bank' ? '谜题库' : '每日谜题'}}</view>
      <view class="field">
        <text>谜题类型</text>
        <picker range="{{puzzleTypeOptions}}" range-key="label" data-form="puzzleForm" data-field="puzzle_type" data-options="puzzleTypeOptions" bindchange="onPickerChange">
          <view class="picker-box">{{puzzleForm.puzzle_type === 'bank' ? '谜题库' : '每日谜题'}}</view>
        </picker>
      </view>
      <view class="field" wx:if="{{puzzleForm.puzzle_type === 'daily'}}">
        <text>发布日期</text>
        <picker mode="date" value="{{puzzleForm.publish_date}}" data-form="puzzleForm" data-field="publish_date" bindchange="onDateChange">
          <view class="picker-box">{{puzzleForm.publish_date || '请选择日期'}}</view>
        </picker>
      </view>
      <view class="field"><text>题干</text><textarea value="{{puzzleForm.content}}" data-form="puzzleForm" data-field="content" bindinput="onFormInput" maxlength="300" show-confirm-bar="{{false}}" /></view>
      <view class="grid-2 option-grid">
        <view class="field"><text>选项 A</text><input value="{{puzzleForm.option_a}}" data-form="puzzleForm" data-field="option_a" bindinput="onFormInput" placeholder="填写 A 选项描述" /></view>
        <view class="field"><text>选项 B</text><input value="{{puzzleForm.option_b}}" data-form="puzzleForm" data-field="option_b" bindinput="onFormInput" placeholder="填写 B 选项描述" /></view>
        <view class="field"><text>选项 C</text><input value="{{puzzleForm.option_c}}" data-form="puzzleForm" data-field="option_c" bindinput="onFormInput" placeholder="填写 C 选项描述" /></view>
        <view class="field"><text>选项 D</text><input value="{{puzzleForm.option_d}}" data-form="puzzleForm" data-field="option_d" bindinput="onFormInput" placeholder="填写 D 选项描述" /></view>
      </view>
      <view class="grid-2">
        <view class="field">
          <text>正确答案</text>
          <picker range="{{answerOptions}}" range-key="label" data-form="puzzleForm" data-field="correct_answer" data-options="answerOptions" bindchange="onPickerChange">
            <view class="picker-box">{{puzzleForm.correct_answer || '请选择'}}</view>
          </picker>
        </view>
        <view class="field">
          <text>难度</text>
          <picker range="{{difficultyOptions}}" range-key="label" data-form="puzzleForm" data-field="difficulty" data-options="difficultyOptions" bindchange="onPickerChange">
            <view class="picker-box">{{puzzleForm.difficulty === 'easy' ? '简单' : puzzleForm.difficulty === 'medium' ? '中等' : '困难'}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="field">
          <text>分类</text>
          <picker range="{{puzzleCategoryOptions}}" range-key="label" data-form="puzzleForm" data-field="category" data-options="puzzleCategoryOptions" bindchange="onPickerChange">
            <view class="picker-box">{{puzzleForm.category || '逻辑推理'}}</view>
          </picker>
        </view>
        <view class="field"><text>标签</text><input value="{{puzzleForm.tags}}" data-form="puzzleForm" data-field="tags" bindinput="onFormInput" placeholder="多个用逗号分隔" /></view>
      </view>
      <view class="field"><text>解析</text><textarea value="{{puzzleForm.answer_explanation}}" data-form="puzzleForm" data-field="answer_explanation" bindinput="onFormInput" maxlength="400" show-confirm-bar="{{false}}" /></view>
      <view class="field"><text>奖励积分</text><input type="number" value="{{puzzleForm.reward_points}}" data-form="puzzleForm" data-field="reward_points" bindinput="onFormInput" /></view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="savePuzzle">保存谜题</button>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'activity'}}">
      <view class="panel-title">活动发布</view>
      <view class="field"><text>标题</text><input value="{{activityForm.title}}" data-form="activityForm" data-field="title" bindinput="onFormInput" /></view>
      <view class="field"><text>简介</text><textarea value="{{activityForm.description}}" data-form="activityForm" data-field="description" bindinput="onFormInput" maxlength="300" show-confirm-bar="{{false}}" /></view>
      <view class="grid-2">
        <view class="field"><text>地点</text><input value="{{activityForm.location}}" data-form="activityForm" data-field="location" bindinput="onFormInput" /></view>
        <view class="field"><text>人数上限</text><input type="number" value="{{activityForm.capacity}}" data-form="activityForm" data-field="capacity" bindinput="onFormInput" /></view>
      </view>
      <view class="field">
        <text>活动封面</text>
        <view class="upload-box">
          <image wx:if="{{activityForm.cover_url}}" class="upload-preview" src="{{activityForm.cover_url}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="upload-placeholder">未上传封面</view>
          <text class="upload-hint">建议 16:9 横图，主体居中</text>
          <view class="upload-actions">
            <button class="small-btn" data-form="activityForm" data-field="cover_url" data-dir="admin/activity" loading="{{uploading_field === 'activityForm.cover_url'}}" disabled="{{uploading_field !== ''}}" bindtap="uploadFormImage">上传图片</button>
            <button wx:if="{{activityForm.cover_url}}" class="small-btn ghost" data-form="activityForm" data-field="cover_url" bindtap="clearFormImage">清除</button>
          </view>
        </view>
      </view>
      <view class="date-time-title">最晚取消时间</view>
      <view class="grid-2">
        <view class="field"><picker mode="date" value="{{activityForm.cancel_date}}" data-form="activityForm" data-field="cancel_date" bindchange="onDateChange"><view class="picker-box">{{activityForm.cancel_date || '选择日期'}}</view></picker></view>
        <view class="field"><picker mode="time" value="{{activityForm.cancel_time}}" data-form="activityForm" data-field="cancel_time" bindchange="onTimeChange"><view class="picker-box">{{activityForm.cancel_time || '选择时间'}}</view></picker></view>
      </view>
      <view class="date-time-title">开始时间</view>
      <view class="grid-2">
        <view class="field"><picker mode="date" value="{{activityForm.start_date}}" data-form="activityForm" data-field="start_date" bindchange="onDateChange"><view class="picker-box">{{activityForm.start_date || '选择日期'}}</view></picker></view>
        <view class="field"><picker mode="time" value="{{activityForm.start_time_only}}" data-form="activityForm" data-field="start_time_only" bindchange="onTimeChange"><view class="picker-box">{{activityForm.start_time_only || '选择时间'}}</view></picker></view>
      </view>
      <view class="date-time-title">结束时间</view>
      <view class="grid-2">
        <view class="field"><picker mode="date" value="{{activityForm.end_date}}" data-form="activityForm" data-field="end_date" bindchange="onDateChange"><view class="picker-box">{{activityForm.end_date || '选择日期'}}</view></picker></view>
        <view class="field"><picker mode="time" value="{{activityForm.end_time_only}}" data-form="activityForm" data-field="end_time_only" bindchange="onTimeChange"><view class="picker-box">{{activityForm.end_time_only || '选择时间'}}</view></picker></view>
      </view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="createActivity">创建活动</button>

      <view class="section-divider"></view>
      <view class="panel-title compact">活动参与确认</view>
      <view class="ops-card" wx:for="{{activity_registrations}}" wx:key="registration_id">
        <view class="ops-head">
          <view>
            <text class="ops-title">{{item.activity_title}}</text>
            <text class="ops-meta">{{item.user_name}} · {{item.registered_text || '暂无时间'}}</text>
          </view>
          <text class="badge {{item.status === 'attended' ? 'blue' : ''}}">{{item.status_text}}</text>
        </view>
        <text class="ops-desc" wx:if="{{item.reason}}">报名理由：{{item.reason}}</text>
        <view class="ops-line" wx:if="{{item.from_waitlist}}">
          <text>来源</text>
          <text>候补转正</text>
        </view>
        <view class="ops-actions" wx:if="{{item.can_attend}}">
          <button class="small-btn success" data-id="{{item.registration_id}}" loading="{{processing_id === item.registration_id && saving}}" disabled="{{saving}}" bindtap="confirmActivityAttendance">确认参加</button>
        </view>
        <view class="ops-line" wx:elif="{{item.attend_hint}}">
          <text>签到</text>
          <text>{{item.attend_hint}}</text>
        </view>
      </view>
      <view class="empty" wx:if="{{activity_registrations.length === 0}}">暂无待确认报名</view>

      <view class="section-divider"></view>
      <view class="panel-title compact">候补名单</view>
      <view class="ops-card" wx:for="{{activity_waitlist}}" wx:key="waitlist_id">
        <view class="ops-head">
          <view>
            <text class="ops-title">{{item.activity_title}}</text>
            <text class="ops-meta">{{item.user_name}} · {{item.joined_text || '暂无时间'}}</text>
          </view>
          <text class="badge">候补中</text>
        </view>
        <text class="ops-desc" wx:if="{{item.reason}}">候补理由：{{item.reason}}</text>
      </view>
      <view class="empty" wx:if="{{activity_waitlist.length === 0}}">暂无候补用户</view>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'borrow'}}">
      <view class="panel-title">物资入库</view>
      <view class="field"><text>名称</text><input value="{{borrowForm.item_name}}" data-form="borrowForm" data-field="item_name" bindinput="onFormInput" /></view>
      <view class="field"><text>描述</text><textarea value="{{borrowForm.description}}" data-form="borrowForm" data-field="description" bindinput="onFormInput" maxlength="240" show-confirm-bar="{{false}}" /></view>
      <view class="field">
        <text>物资图片</text>
        <view class="upload-box">
          <image wx:if="{{borrowForm.cover_url}}" class="upload-preview" src="{{borrowForm.cover_url}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="upload-placeholder">未上传图片</view>
          <text class="upload-hint">建议 3:4 或 1:1，物品完整入画</text>
          <view class="upload-actions">
            <button class="small-btn" data-form="borrowForm" data-field="cover_url" data-dir="admin/inventory" loading="{{uploading_field === 'borrowForm.cover_url'}}" disabled="{{uploading_field !== ''}}" bindtap="uploadFormImage">上传图片</button>
            <button wx:if="{{borrowForm.cover_url}}" class="small-btn ghost" data-form="borrowForm" data-field="cover_url" bindtap="clearFormImage">清除</button>
          </view>
        </view>
      </view>
      <view class="grid-2">
        <view class="field">
          <text>物资类型</text>
          <picker range="{{itemTypeOptions}}" range-key="label" data-form="borrowForm" data-field="item_type" data-options="itemTypeOptions" bindchange="onPickerChange">
            <view class="picker-box">{{borrowForm.item_type === 'book' ? '书籍' : borrowForm.item_type === 'script' ? '剧本杀' : '道具/物资'}}</view>
          </picker>
        </view>
        <view class="field">
          <text>分类</text>
          <picker range="{{inventoryCategoryOptions}}" range-key="label" data-form="borrowForm" data-field="category" data-options="inventoryCategoryOptions" bindchange="onPickerChange">
            <view class="picker-box">{{borrowForm.category === 'book' ? '推理小说' : borrowForm.category === 'script' ? '剧本杀' : borrowForm.category === 'activity' ? '活动物资' : borrowForm.category === 'boardgame' ? '桌游道具' : '其他'}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="field"><text>数量</text><input type="number" value="{{borrowForm.total_quantity}}" data-form="borrowForm" data-field="total_quantity" bindinput="onFormInput" /></view>
        <view class="field">
          <text>剧本类型</text>
          <picker range="{{scriptGenreOptions}}" range-key="label" data-form="borrowForm" data-field="genre" data-options="scriptGenreOptions" bindchange="onPickerChange">
            <view class="picker-box">{{borrowForm.genre || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-3">
        <view class="field"><text>最少人数</text><input type="number" value="{{borrowForm.min_players}}" data-form="borrowForm" data-field="min_players" bindinput="onFormInput" /></view>
        <view class="field"><text>最多人数</text><input type="number" value="{{borrowForm.max_players}}" data-form="borrowForm" data-field="max_players" bindinput="onFormInput" /></view>
        <view class="field"><text>时长分钟</text><input type="number" value="{{borrowForm.duration_minutes}}" data-form="borrowForm" data-field="duration_minutes" bindinput="onFormInput" /></view>
      </view>
      <view class="field">
        <text>难度</text>
        <picker range="{{difficultyOptions}}" range-key="label" data-form="borrowForm" data-field="difficulty" data-options="difficultyOptions" bindchange="onPickerChange">
          <view class="picker-box">{{borrowForm.difficulty === 'easy' ? '简单' : borrowForm.difficulty === 'medium' ? '中等' : '困难'}}</view>
        </picker>
      </view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="createBorrowItem">添加物资</button>

      <view class="section-divider"></view>
      <view class="panel-title compact">借阅交付处理</view>
      <view class="filter-bar">
        <picker range="{{borrowFilterOptions}}" range-key="label" data-filter="borrowFilters" data-options="borrowFilterOptions" bindchange="onFilterStatusChange">
          <view class="filter-chip">状态：{{borrowFilters.status === 'active' ? '处理中' : borrowFilters.status === 'all' ? '全部' : borrowFilters.status}}</view>
        </picker>
        <picker mode="date" value="{{borrowFilters.start_date}}" data-filter="borrowFilters" data-field="start_date" bindchange="onFilterDateChange">
          <view class="filter-chip">开始：{{borrowFilters.start_date || '不限'}}</view>
        </picker>
        <picker mode="date" value="{{borrowFilters.end_date}}" data-filter="borrowFilters" data-field="end_date" bindchange="onFilterDateChange">
          <view class="filter-chip">结束：{{borrowFilters.end_date || '不限'}}</view>
        </picker>
        <button class="small-btn export-btn" data-type="borrow" bindtap="exportCsv">导出 CSV</button>
      </view>
      <view class="ops-card" wx:for="{{borrow_applications}}" wx:key="application_id">
        <view class="ops-head">
          <view>
            <text class="ops-title">{{item.item_name}}</text>
            <text class="ops-meta">{{item.borrower_name}} · {{item.created_text || '暂无时间'}}</text>
          </view>
          <text class="badge {{item.status === 'borrowed' ? 'blue' : ''}}">{{item.status_text}}</text>
        </view>
        <text class="ops-desc" wx:if="{{item.reason}}">用途：{{item.reason}}</text>
        <view class="ops-actions">
          <button wx:if="{{item.can_lend}}" class="small-btn" data-id="{{item.application_id}}" data-status="borrowed" loading="{{processing_id === item.application_id && saving}}" disabled="{{saving}}" bindtap="updateBorrowStatus">确认借出</button>
          <button wx:if="{{item.can_return}}" class="small-btn success" data-id="{{item.application_id}}" data-status="returned" loading="{{processing_id === item.application_id && saving}}" disabled="{{saving}}" bindtap="updateBorrowStatus">确认归还</button>
          <button wx:if="{{item.can_cancel}}" class="small-btn ghost" data-id="{{item.application_id}}" data-status="cancelled" loading="{{processing_id === item.application_id && saving}}" disabled="{{saving}}" bindtap="updateBorrowStatus">取消</button>
        </view>
      </view>
      <view class="empty" wx:if="{{borrow_applications.length === 0}}">暂无待处理借阅</view>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'exchange'}}">
      <view class="panel-title">兑换商品</view>
      <view class="field"><text>名称</text><input value="{{exchangeForm.item_name}}" data-form="exchangeForm" data-field="item_name" bindinput="onFormInput" /></view>
      <view class="field"><text>描述</text><textarea value="{{exchangeForm.description}}" data-form="exchangeForm" data-field="description" bindinput="onFormInput" maxlength="240" show-confirm-bar="{{false}}" /></view>
      <view class="field">
        <text>商品图片</text>
        <view class="upload-box">
          <image wx:if="{{exchangeForm.cover_url}}" class="upload-preview" src="{{exchangeForm.cover_url}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="upload-placeholder">未上传图片</view>
          <text class="upload-hint">建议 1:1 方图，商品居中</text>
          <view class="upload-actions">
            <button class="small-btn" data-form="exchangeForm" data-field="cover_url" data-dir="admin/exchange" loading="{{uploading_field === 'exchangeForm.cover_url'}}" disabled="{{uploading_field !== ''}}" bindtap="uploadFormImage">上传图片</button>
            <button wx:if="{{exchangeForm.cover_url}}" class="small-btn ghost" data-form="exchangeForm" data-field="cover_url" bindtap="clearFormImage">清除</button>
          </view>
        </view>
      </view>
      <view class="field">
        <text>分类</text>
        <picker range="{{exchangeCategoryOptions}}" range-key="label" data-form="exchangeForm" data-field="category" data-options="exchangeCategoryOptions" bindchange="onPickerChange">
          <view class="picker-box">{{exchangeForm.category === 'general' ? '通用' : exchangeForm.category === 'merch' ? '社团周边' : exchangeForm.category === 'activity' ? '活动奖励' : exchangeForm.category === 'book' ? '书籍/资料' : '其他'}}</view>
        </picker>
      </view>
      <view class="grid-2">
        <view class="field">
          <text>运营标签</text>
          <picker range="{{exchangeTagOptions}}" range-key="label" data-form="exchangeForm" data-field="tag_type" data-options="exchangeTagOptions" bindchange="onPickerChange">
            <view class="picker-box">{{exchangeForm.tag_type === 'new' ? '新品' : exchangeForm.tag_type === 'limited' ? '限量' : exchangeForm.tag_type === 'limited_time' ? '限时' : '无标签'}}</view>
          </picker>
        </view>
        <view class="field"><text>标签文案</text><input value="{{exchangeForm.tag_text}}" data-form="exchangeForm" data-field="tag_text" bindinput="onFormInput" placeholder="默认使用标签名" /></view>
      </view>
      <view class="grid-3">
        <view class="field"><text>兑换积分</text><input type="number" value="{{exchangeForm.exchange_points}}" data-form="exchangeForm" data-field="exchange_points" bindinput="onFormInput" /></view>
        <view class="field"><text>原价</text><input type="number" value="{{exchangeForm.original_cost}}" data-form="exchangeForm" data-field="original_cost" bindinput="onFormInput" /></view>
        <view class="field"><text>库存</text><input type="number" value="{{exchangeForm.total_quantity}}" data-form="exchangeForm" data-field="total_quantity" bindinput="onFormInput" /></view>
      </view>
      <view class="field"><text>库存预警阈值</text><input type="number" value="{{exchangeForm.stock_warning_threshold}}" data-form="exchangeForm" data-field="stock_warning_threshold" bindinput="onFormInput" placeholder="默认 3" /></view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="createExchangeGood">添加商品</button>

      <view class="section-divider"></view>
      <view class="panel-title compact">商品运营管理</view>
      <view class="ops-card" wx:for="{{exchange_goods}}" wx:key="item_id">
        <view class="ops-head">
          <view>
            <text class="ops-title">{{item.item_name}}</text>
            <text class="ops-meta">{{item.exchange_points}} 积分 · 库存 {{item.stock_text}}</text>
          </view>
          <text class="badge {{item.status === 'available' ? 'blue' : ''}}">{{item.status_text}}</text>
        </view>
        <view class="ops-line">
          <text wx:if="{{item.tag_display}}">{{item.tag_display}}</text>
          <text wx:else>无标签</text>
          <text class="{{item.stock_warning ? 'warn-text' : ''}}">{{item.stock_warning ? '库存预警' : '库存正常'}}</text>
        </view>
        <view class="ops-actions">
          <button wx:if="{{item.can_online}}" class="small-btn" data-id="{{item.item_id}}" data-status="available" loading="{{processing_id === item.item_id && saving}}" disabled="{{saving}}" bindtap="updateExchangeGoodStatus">上架</button>
          <button wx:if="{{item.can_offline}}" class="small-btn ghost" data-id="{{item.item_id}}" data-status="offline" loading="{{processing_id === item.item_id && saving}}" disabled="{{saving}}" bindtap="updateExchangeGoodStatus">下架</button>
        </view>
      </view>
      <view class="empty" wx:if="{{exchange_goods.length === 0}}">暂无兑换商品</view>

      <view class="section-divider"></view>
      <view class="panel-title compact">兑换领取处理</view>
      <view class="filter-bar">
        <picker range="{{exchangeRecordFilterOptions}}" range-key="label" data-filter="exchangeRecordFilters" data-options="exchangeRecordFilterOptions" bindchange="onFilterStatusChange">
          <view class="filter-chip">状态：{{exchangeRecordFilters.status === 'active' ? '处理中' : exchangeRecordFilters.status === 'all' ? '全部' : exchangeRecordFilters.status}}</view>
        </picker>
        <picker mode="date" value="{{exchangeRecordFilters.start_date}}" data-filter="exchangeRecordFilters" data-field="start_date" bindchange="onFilterDateChange">
          <view class="filter-chip">开始：{{exchangeRecordFilters.start_date || '不限'}}</view>
        </picker>
        <picker mode="date" value="{{exchangeRecordFilters.end_date}}" data-filter="exchangeRecordFilters" data-field="end_date" bindchange="onFilterDateChange">
          <view class="filter-chip">结束：{{exchangeRecordFilters.end_date || '不限'}}</view>
        </picker>
        <button class="small-btn export-btn" data-type="exchange" bindtap="exportCsv">导出 CSV</button>
      </view>
      <view class="ops-card" wx:for="{{exchange_records}}" wx:key="exchange_id">
        <view class="ops-head">
          <view>
            <text class="ops-title">{{item.goods_name || item.item_name || '兑换商品'}}</text>
            <text class="ops-meta">{{item.user_name}} · {{item.created_text || '暂无时间'}}</text>
          </view>
          <text class="badge">{{item.status_text}}</text>
        </view>
        <view class="ops-line">
          <text>数量 {{item.quantity_text}}</text>
          <text>{{item.total_cost_text}} 积分</text>
        </view>
        <view class="ops-line" wx:if="{{item.pickup_code}}">
          <text>领取码</text>
          <text>{{item.pickup_code}}</text>
        </view>
        <view class="ops-actions" wx:if="{{item.can_process}}">
          <button class="small-btn success" data-id="{{item.exchange_id}}" data-status="completed" loading="{{processing_id === item.exchange_id && saving}}" disabled="{{saving}}" bindtap="updateExchangeStatus">完成领取</button>
          <button class="small-btn ghost" data-id="{{item.exchange_id}}" data-status="cancelled" loading="{{processing_id === item.exchange_id && saving}}" disabled="{{saving}}" bindtap="updateExchangeStatus">取消兑换</button>
        </view>
      </view>
      <view class="empty" wx:if="{{exchange_records.length === 0}}">暂无待处理兑换</view>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'recommendation'}}">
      <view class="panel-title">推荐内容发布</view>
      <view class="field"><text>名称</text><input value="{{recommendationForm.title}}" data-form="recommendationForm" data-field="title" bindinput="onFormInput" /></view>
      <view class="grid-2">
        <view class="field">
          <text>类型</text>
          <picker range="{{recommendationCategoryOptions}}" range-key="label" data-form="recommendationForm" data-field="category" data-options="recommendationCategoryOptions" bindchange="onPickerChange">
            <view class="picker-box">{{recommendationForm.category === 'book' ? '书籍' : recommendationForm.category === 'game' ? '游戏' : recommendationForm.category === 'script' ? '剧本' : recommendationForm.category === 'activity' ? '活动' : recommendationForm.category === 'media' ? '影视' : '其他'}}</view>
          </picker>
        </view>
        <view class="field"><text>推荐人</text><input value="{{recommendationForm.recommender_name}}" data-form="recommendationForm" data-field="recommender_name" bindinput="onFormInput" placeholder="默认 NK推协" /></view>
      </view>
      <view class="field"><text>推荐理由</text><textarea value="{{recommendationForm.reason}}" data-form="recommendationForm" data-field="reason" bindinput="onFormInput" maxlength="500" show-confirm-bar="{{false}}" /></view>
      <view class="field"><text>外链</text><input value="{{recommendationForm.link_url}}" data-form="recommendationForm" data-field="link_url" bindinput="onFormInput" placeholder="公众号文章或说明链接" /></view>
      <view class="field">
        <text>封面图</text>
        <view class="upload-box">
          <image wx:if="{{recommendationForm.cover_url}}" class="upload-preview" src="{{recommendationForm.cover_url}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="upload-placeholder">未上传封面</view>
          <text class="upload-hint">建议 4:3 封面图，标题主体避开边缘</text>
          <view class="upload-actions">
            <button class="small-btn" data-form="recommendationForm" data-field="cover_url" data-dir="admin/recommendation" loading="{{uploading_field === 'recommendationForm.cover_url'}}" disabled="{{uploading_field !== ''}}" bindtap="uploadFormImage">上传图片</button>
            <button wx:if="{{recommendationForm.cover_url}}" class="small-btn ghost" data-form="recommendationForm" data-field="cover_url" bindtap="clearFormImage">清除</button>
          </view>
        </view>
      </view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="createRecommendation">发布推荐</button>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'dud'}}">
      <view class="panel-title">Dud 关键词</view>
      <view class="field"><text>关键词</text><input value="{{dudForm.keyword}}" data-form="dudForm" data-field="keyword" bindinput="onFormInput" /></view>
      <view class="field"><text>回复</text><textarea value="{{dudForm.reply_content}}" data-form="dudForm" data-field="reply_content" bindinput="onFormInput" maxlength="300" show-confirm-bar="{{false}}" /></view>
      <view class="grid-2">
        <view class="field">
          <text>分类</text>
          <picker range="{{dudCategoryOptions}}" range-key="label" data-form="dudForm" data-field="category" data-options="dudCategoryOptions" bindchange="onPickerChange">
            <view class="picker-box">{{dudForm.category === 'general' ? '通用' : dudForm.category === 'activity' ? '活动相关' : dudForm.category === 'puzzle' ? '谜题相关' : dudForm.category === 'ranking' ? '排行相关' : dudForm.category === 'commission' ? '委托相关' : dudForm.category === 'help' ? '帮助指引' : '通用'}}</view>
          </picker>
        </view>
        <view class="field">
          <text>匹配方式</text>
          <picker range="{{matchTypeOptions}}" range-key="label" data-form="dudForm" data-field="match_type" data-options="matchTypeOptions" bindchange="onPickerChange">
            <view class="picker-box">{{dudForm.match_type === 'exact' ? '精确匹配' : '模糊匹配'}}</view>
          </picker>
        </view>
      </view>
      <view class="field"><text>优先级</text><input type="number" value="{{dudForm.priority}}" data-form="dudForm" data-field="priority" bindinput="onFormInput" /></view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="createDudKeyword">添加关键词</button>
    </view>

    <!-- 交友管理 -->
    <view class="panel" wx:if="{{!error && tab === 'dating'}}">
      <view class="panel-title">交友管理</view>

      <!-- 统计 -->
      <view class="panel-row" wx:if="{{dating_stats}}">
        <view class="panel-stat">
          <text class="panel-stat-label">交友池人数</text>
          <text class="panel-stat-value">{{dating_stats.pool_size || 0}}</text>
        </view>
        <view class="panel-stat">
          <text class="panel-stat-label">总匹配数</text>
          <text class="panel-stat-value">{{dating_stats.total_matches || 0}}</text>
        </view>
        <view class="panel-stat">
          <text class="panel-stat-label">今日新匹配</text>
          <text class="panel-stat-value">{{dating_stats.today_matches || 0}}</text>
        </view>
      </view>

      <!-- 交友池用户列表 -->
      <view class="panel-subtitle">交友池用户</view>
      <view class="list-row" wx:for="{{dating_pool}}" wx:key="user_id" wx:for-index="index">
        <text class="list-index">{{index + 1}}</text>
        <view class="list-info">
          <text class="list-title">{{item.user_id}}</text>
          <text class="list-desc">{{item.campus || ''}} {{item.grade || ''}}</text>
        </view>
        <view class="list-status-tag {{item.is_active ? 'online' : 'offline'}}">{{item.is_active ? '活跃' : '离线'}}</view>
        <button class="small-btn danger-btn" data-user-id="{{item.user_id}}" bindtap="adminRemoveFromPool" wx:if="{{item.is_active}}">移除</button>
      </view>

      <!-- 匹配记录 -->
      <view class="panel-subtitle" style="margin-top: 32rpx;">匹配记录</view>
      <view class="list-row" wx:for="{{dating_matches}}" wx:key="match_id" wx:for-index="index">
        <text class="list-index">{{index + 1}}</text>
        <view class="list-info">
          <text class="list-title">{{item.match_id}}</text>
          <text class="list-desc">{{item.user_id_1}} ↔ {{item.user_id_2}}</text>
        </view>
        <view class="list-status-tag {{item.is_active ? 'online' : 'offline'}}">{{item.is_active ? '活跃' : '已解除'}}</view>
        <button class="small-btn danger-btn" data-match-id="{{item.match_id}}" bindtap="adminDeactivateMatch" wx:if="{{item.is_active}}">解除</button>
      </view>

      <empty-state wx:if="{{!dating_pool.length && !dating_matches.length}}" icon="💬" title="暂无交友数据" />
    </view>

    <view class="panel" wx:if="{{!error && tab === 'feedback'}}">
      <view class="panel-title">反馈处理</view>
      <view class="filter-bar">
        <picker range="{{feedbackFilterOptions}}" range-key="label" data-filter="feedbackFilters" data-options="feedbackFilterOptions" bindchange="onFilterStatusChange">
          <view class="filter-chip">状态：{{feedbackFilters.status === 'active' ? '处理中' : feedbackFilters.status === 'all' ? '全部' : feedbackFilters.status}}</view>
        </picker>
        <picker mode="date" value="{{feedbackFilters.start_date}}" data-filter="feedbackFilters" data-field="start_date" bindchange="onFilterDateChange">
          <view class="filter-chip">开始：{{feedbackFilters.start_date || '不限'}}</view>
        </picker>
        <picker mode="date" value="{{feedbackFilters.end_date}}" data-filter="feedbackFilters" data-field="end_date" bindchange="onFilterDateChange">
          <view class="filter-chip">结束：{{feedbackFilters.end_date || '不限'}}</view>
        </picker>
        <button class="small-btn export-btn" data-type="feedback" bindtap="exportCsv">导出 CSV</button>
      </view>
      <view class="feedback-card" wx:for="{{feedback_list}}" wx:key="feedback_id" wx:for-index="index">
        <view class="feedback-head">
          <text class="feedback-title">{{item.feedback_title}}</text>
          <text class="badge {{item.status === 'resolved' ? 'done' : ''}}">{{item.status_text}}</text>
        </view>
        <text class="feedback-content">{{item.content}}</text>
        <text class="feedback-time">{{item.created_text}} {{item.anonymous_text}}</text>
        <view class="field reply-field">
          <text>回复消息</text>
          <textarea value="{{item.reply_draft}}" data-index="{{index}}" bindinput="onFeedbackReplyInput" maxlength="300" show-confirm-bar="{{false}}" placeholder="填写给用户看的处理回复" />
        </view>
        <button wx:if="{{item.status !== 'resolved'}}" class="small-btn" data-id="{{item.feedback_id}}" data-index="{{index}}" loading="{{processing_id === item.feedback_id && saving}}" disabled="{{saving}}" bindtap="resolveFeedback">回复并标记处理</button>
      </view>
      <view class="empty" wx:if="{{feedback_list.length === 0}}">暂无反馈</view>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'logs'}}">
      <view class="panel-title">后台操作日志</view>
      <view class="log-card" wx:for="{{log_list}}" wx:key="log_id">
        <view class="log-head">
          <text class="log-operation">{{item.operation_text}}</text>
          <text class="log-time">{{item.created_text}}</text>
        </view>
        <text class="log-target">{{item.target_text}} / {{item.target_id_text}}</text>
        <text class="log-admin">管理员：{{item.admin_id}}</text>
      </view>
      <view class="empty" wx:if="{{log_list.length === 0}}">暂无操作日志</view>
    </view>

    <view class="panel" wx:if="{{!error && tab === 'settings'}}">
      <view class="panel-title">系统参数</view>
      <view class="grid-2">
        <view class="field">
          <text>谜题发布时间</text>
          <picker range="{{publishTimeOptions}}" range-key="label" data-form="systemSettingsForm" data-field="puzzle_publish_time" data-options="publishTimeOptions" bindchange="onPickerChange">
            <view class="picker-box">{{systemSettingsForm.puzzle_publish_time}}</view>
          </picker>
        </view>
        <view class="field"><text>默认谜题奖励</text><input type="number" value="{{systemSettingsForm.default_puzzle_reward}}" data-form="systemSettingsForm" data-field="default_puzzle_reward" bindinput="onFormInput" /></view>
      </view>
      <view class="field">
        <text>活动取消提前小时数</text>
        <picker range="{{cancelHourOptions}}" range-key="label" data-form="systemSettingsForm" data-field="activity_cancel_hours" data-options="cancelHourOptions" bindchange="onPickerChange">
          <view class="picker-box">{{systemSettingsForm.activity_cancel_hours}} 小时</view>
        </picker>
      </view>
      <view class="switch-row">
        <view>
          <text class="switch-title">推荐内容展示</text>
          <text class="switch-desc">关闭后可在后续首页逻辑中隐藏推荐入口</text>
        </view>
        <switch checked="{{systemSettingsForm.recommendation_enabled}}" data-form="systemSettingsForm" data-field="recommendation_enabled" bindchange="onFormSwitch" />
      </view>
      <view class="switch-row">
        <view>
          <text class="switch-title">事件委托开放</text>
          <text class="switch-desc">用于临时关闭委托发布与领取入口</text>
        </view>
        <switch checked="{{systemSettingsForm.commission_enabled}}" data-form="systemSettingsForm" data-field="commission_enabled" bindchange="onFormSwitch" />
      </view>
      <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="saveSystemSettings">保存系统设置</button>
    </view>
  </scroll-view>
</view>

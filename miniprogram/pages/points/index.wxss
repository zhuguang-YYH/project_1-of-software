.page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #263241;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #69788b;
  font-size: 26rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #d9e8f7;
  border-top-color: #2477c3;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.summary {
  margin: 24rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(22, 34, 51, 0.06);
}

.summary-main {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #edf2f7;
}

.summary-label,
.item-label {
  display: block;
  color: #7a8797;
  font-size: 24rpx;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #2477c3;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  padding-top: 24rpx;
}

.summary-item {
  min-width: 0;
}

.item-value {
  display: block;
  margin-top: 8rpx;
  color: #263241;
  font-size: 32rpx;
  font-weight: 700;
}

.item-value.frozen {
  color: #c2410c;
}

.error-banner {
  margin: 0 24rpx 18rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 25rpx;
}

.filter-row {
  margin: 0 24rpx 18rpx;
  padding: 6rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  border-radius: 8rpx;
  background: #e8eef6;
}

.filter-item {
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 6rpx;
  text-align: center;
  color: #64748b;
  font-size: 24rpx;
}

.filter-item.active {
  background: #ffffff;
  color: #2477c3;
  font-weight: 700;
}

.log-list {
  padding: 0 24rpx;
}

.log-card {
  margin-bottom: 14rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.log-left {
  flex: 1;
  min-width: 0;
}

.log-reason {
  display: block;
  color: #263241;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.log-meta {
  display: block;
  margin-top: 8rpx;
  color: #8a96a8;
  font-size: 22rpx;
}

.log-amount {
  flex: 0 0 auto;
  font-size: 34rpx;
  font-weight: 800;
}

.log-amount.income {
  color: #15803d;
}

.log-amount.expense {
  color: #be123c;
}

.empty-state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-title,
.empty-text {
  display: block;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3b4c;
}

.empty-text {
  margin-top: 12rpx;
  color: #8a96a8;
  font-size: 25rpx;
}

.load-more {
  padding: 18rpx 0 44rpx;
  text-align: center;
  color: #7a8797;
  font-size: 24rpx;
}

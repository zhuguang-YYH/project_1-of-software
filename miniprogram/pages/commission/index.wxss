  box-shadow: 0 12rpx 26rpx rgba(212, 175, 55, 0.22) !important;
}

.theme-gold .card-actions .claim-btn.expired-btn,
.theme-gold .card-actions .claim-btn.owner-btn,
.theme-gold .card-actions .claim-btn.unavailable-btn,
.theme-gold .card-actions .claim-btn.status-btn-withdrawn,
.theme-gold .card-actions .claim-btn.status-btn-closed {
  color: rgba(244, 236, 214, 0.78) !important;
  background: rgba(255, 255, 255, 0.07) !important;
  border: 1rpx solid rgba(212, 175, 55, 0.16) !important;
  box-shadow: none !important;
}

.theme-gold .card-actions .claim-btn.accepted-btn,
.theme-gold .card-actions .claim-btn.status-btn-completed,
.theme-gold .card-actions .claim-btn.status-btn-rewarded,
.theme-gold .card-actions .claim-btn.status-btn-resolved {
  color: #17110a !important;
  background: linear-gradient(135deg, #ffe9a3 0%, #cfa93a 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(212, 175, 55, 0.20) !important;
}

.theme-gold .card-actions .claim-btn[disabled] {
  opacity: 1 !important;
}

.theme-gold .modal-mask {
  background: rgba(0, 0, 0, 0.68) !important;
}

.theme-gold .close-btn {
  color: #f8e7a8 !important;
  background: rgba(212, 175, 55, 0.12) !important;
  border: 1rpx solid rgba(212, 175, 55, 0.22) !important;
}

.theme-gold .field input,
.theme-gold .field textarea,

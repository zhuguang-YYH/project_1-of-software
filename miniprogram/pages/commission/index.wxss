.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
  color: #1a1f3a;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.summary {
  position: relative;
  margin: 24rpx;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #3a4cd1 0%, #5b6cff 100%);
  border-radius: 24rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 176rpx;
  gap: 16rpx;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(91, 108, 255, 0.3);
  color: #fff;
  overflow: hidden;
}

.summary > view,
.summary > button {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.summary::before {
  content: '';
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  top: -80rpx;
  right: -60rpx;
  pointer-events: none;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.78);
  position: relative;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  position: relative;
}

.summary-value.frozen {
  color: #ffd58c;
}

.publish-btn,
.primary-btn,
.small-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  color: #ffffff !important;
  background: linear-gradient(135deg, #5b6cff, #3a4cd1) !important;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.28);
  font-weight: 700;
  border: none !important;
}

.publish-btn {
  width: 176rpx !important;
  height: 72rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  background: #fff !important;
  color: #3a4cd1 !important;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.12);
  white-space: nowrap;
  word-break: keep-all;
  word-wrap: normal;
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4a5577 !important;
  background: #f4f6fb !important;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  font-weight: 600;
  border: none !important;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a96a8 !important;
  background: #f4f6fb !important;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  font-weight: 500;
  border: none !important;
}

.publish-btn::after,
.primary-btn::after,
.secondary-btn::after,
.ghost-btn::after,
.small-primary::after { border: none !important; }

.small-primary {
  min-width: 184rpx;
  height: 64rpx;
  line-height: 1.2;
  font-size: 25rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.error-banner {
  margin: 0 24rpx 20rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab-nav {
  margin: 0 24rpx 20rpx;
  height: 84rpx;
  padding: 8rpx;
  background: #ffffff;
  border-radius: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  box-shadow: 0 6rpx 18rpx rgba(91, 108, 255, 0.08);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #8a96a8;
  font-size: 26rpx;
  transition: all 0.25s;
}

.tab-item.active {
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.3);
}

.list {
  padding: 0 24rpx 36rpx;
}

.commission-card {
  position: relative;
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.08);
  overflow: hidden;
}

.commission-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #5b6cff, #f5b041);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.card-meta,
.acceptance-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.status {
  flex: 0 0 auto;
  min-width: 108rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  background: #e2e8f0;
  text-align: center;
}

.status-recruiting {
  color: #166534;
  background: #dcfce7;
}

.status-in_progress,
.status-accepted {
  color: #3a4cd1;
  background: #eef0ff;
}

.status-completed {
  color: #92580d;
  background: #fef3df;
}

.status-resolved,
.status-rewarded {
  color: #5b21b6;
  background: #ede9fe;
}

.desc {
  display: -webkit-box;
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #445166;
  overflow: hidden;
  word-break: break-word;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.info-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.info-item {
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #eef0ff, #fef3df);
  min-width: 0;
  text-align: center;
}

.info-label {
  display: block;
  font-size: 21rpx;
  color: #4a5577;
}

.info-value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #3a4cd1;
  word-break: break-all;
}

.deadline-value {
  margin-top: 6rpx;
  color: #3a4cd1;
  font-weight: 800;
  text-align: center;
}

.deadline-date,
.deadline-time {
  display: block;
  line-height: 1.28;
  white-space: nowrap;
}

.deadline-date {
  font-size: 26rpx;
}

.deadline-time {
  margin-top: 4rpx;
  font-size: 28rpx;
}

.card-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.card-actions button {
  margin: 0;
  min-width: 184rpx;
}

.card-actions .claim-btn {
  position: relative;
  width: 100% !important;
  height: 76rpx !important;
  line-height: 76rpx !important;
  border-radius: 999rpx !important;
  overflow: hidden;
  font-size: 28rpx !important;
  letter-spacing: 2rpx;
  background: linear-gradient(135deg, #6f7cff 0%, #4b5de8 100%) !important;
  box-shadow: 0 12rpx 24rpx rgba(75, 93, 232, 0.28);
}

.card-actions .claim-btn::before {
  content: '';
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 8rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.35);
}

.card-actions .claim-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 14rpx rgba(75, 93, 232, 0.24);
}

.card-actions .claim-btn.expired-btn {
  color: #92400e !important;
  background: linear-gradient(135deg, #fff7ed 0%, #f8d889 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(245, 176, 65, 0.22);
}

.card-actions .claim-btn.expired-btn[disabled] {
  opacity: 1 !important;
  color: #92400e !important;
}

.card-actions .claim-btn.expired-btn:active {
  transform: none;
  box-shadow: 0 10rpx 22rpx rgba(245, 176, 65, 0.22);
}

.card-actions .claim-btn.accepted-btn {
  color: #ffffff !important;
  background: linear-gradient(135deg, #34d399 0%, #16a085 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(22, 160, 133, 0.22);
}

.card-actions .claim-btn.accepted-btn[disabled] {
  opacity: 1 !important;
  color: #ffffff !important;
}

.card-actions .claim-btn.accepted-btn:active {
  transform: none;
  box-shadow: 0 10rpx 22rpx rgba(22, 160, 133, 0.22);
}

.card-actions .claim-btn.status-btn,
.card-actions .claim-btn.owner-btn,
.card-actions .claim-btn.unavailable-btn {
  transform: none;
  opacity: 1 !important;
}

.card-actions .claim-btn.owner-btn {
  color: #3a4cd1 !important;
  background: linear-gradient(135deg, #eef0ff 0%, #dfe4ff 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(91, 108, 255, 0.14);
}

.card-actions .claim-btn.unavailable-btn {
  color: #64748b !important;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(100, 116, 139, 0.12);
}

.card-actions .claim-btn.status-btn-accepted,
.card-actions .claim-btn.status-btn-in_progress {
  color: #ffffff !important;
  background: linear-gradient(135deg, #6f7cff 0%, #4b5de8 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(75, 93, 232, 0.22);
}

.card-actions .claim-btn.status-btn-completed,
.card-actions .claim-btn.status-btn-rewarded,
.card-actions .claim-btn.status-btn-resolved {
  color: #ffffff !important;
  background: linear-gradient(135deg, #34d399 0%, #16a085 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(22, 160, 133, 0.22);
}

.card-actions .claim-btn.status-btn-withdrawn,
.card-actions .claim-btn.status-btn-closed {
  color: #64748b !important;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%) !important;
  box-shadow: 0 10rpx 22rpx rgba(100, 116, 139, 0.12);
}

.card-actions .claim-btn.status-btn:active,
.card-actions .claim-btn.owner-btn:active,
.card-actions .claim-btn.unavailable-btn:active {
  transform: none;
}

.acceptance-list {
  margin-top: 22rpx;
  border-top: 1rpx solid #edf2f7;
}

.acceptance-item {
  padding: 20rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.receiver {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: #334155;
}

.no-acceptance {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
  color: #8a96a8;
  font-size: 25rpx;
}

.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #7b8794;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #475569;
}

.empty-text {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.5;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
}

.modal {
  width: 100%;
  max-height: 88vh;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  animation: slide-up 0.3s ease;
  overflow-y: auto;
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal.small {
  max-height: 56vh;
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.close-btn {
  width: 64rpx !important;
  height: 64rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 64rpx !important;
  border-radius: 50% !important;
  font-size: 30rpx;
  font-weight: 700;
  color: #64748b;
  background: #edf2f7 !important;
  box-shadow: none !important;
}

.close-btn::after {
  border: none !important;
}

.form {
  margin-top: 24rpx;
}

.field {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  line-height: 1.35;
  font-size: 25rpx;
  color: #475569;
  font-weight: 700;
}

.field input,
.field textarea,
.reward-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f4f6fb;
  color: #1a1f3a;
  font-size: 27rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.field input,
.reward-input {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
}

.field textarea {
  min-height: 180rpx;
  padding: 18rpx 20rpx;
  line-height: 1.55;
}

.counter,
.hint {
  display: block;
  margin-top: 8rpx;
  line-height: 1.4;
  font-size: 22rpx;
  color: #8a96a8;
}

.deadline-picker-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.deadline-picker-row picker {
  min-width: 0;
  width: 100%;
}

.picker-input {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  border-radius: 14rpx;
  background: #f4f6fb;
  color: #1a1f3a;
  font-size: 27rpx;
}

.field-error {
  display: block;
  margin-top: 8rpx;
  line-height: 1.4;
  font-size: 22rpx;
  color: #dc2626;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 20rpx 0 6rpx;
  background: #ffffff;
  position: sticky;
  bottom: 0;
}

.modal-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx !important;
  margin: 0 !important;
  line-height: 84rpx !important;
  border-radius: 999rpx !important;
  font-size: 28rpx !important;
  font-weight: 800 !important;
}

.modal-actions .secondary-btn {
  color: #334155 !important;
  background: #eef2f7 !important;
}

.modal-actions .primary-btn {
  background: linear-gradient(135deg, #6f7cff 0%, #3a4cd1 100%) !important;
  box-shadow: 0 12rpx 24rpx rgba(58, 76, 209, 0.24);
}

.reward-box {
  margin-top: 28rpx;
}

.reward-name {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #334155;
}

/* 黑金主题：委托页局部控件可读性修正 */

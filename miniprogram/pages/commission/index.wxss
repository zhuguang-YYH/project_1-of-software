.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
  color: #1a1f3a;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.summary {
  position: relative;
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #3a4cd1 0%, #5b6cff 100%);
  border-radius: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 160rpx;
  gap: 20rpx;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(91, 108, 255, 0.3);
  color: #fff;
  overflow: hidden;
}

.summary::before {
  content: '';
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  top: -80rpx;
  right: -60rpx;
  pointer-events: none;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.78);
  position: relative;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  position: relative;
}

.summary-value.frozen {
  color: #ffd58c;
}

.publish-btn,
.primary-btn,
.small-primary {
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  color: #ffffff !important;
  background: linear-gradient(135deg, #5b6cff, #3a4cd1) !important;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.28);
  font-weight: 700;
  border: none !important;
}

.publish-btn {
  background: #fff !important;
  color: #3a4cd1 !important;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.12);
}

.secondary-btn {
  color: #4a5577 !important;
  background: #f4f6fb !important;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  font-weight: 600;
  border: none !important;
}

.ghost-btn {
  color: #8a96a8 !important;
  background: #f4f6fb !important;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  font-weight: 500;
  border: none !important;
}

.publish-btn::after,
.primary-btn::after,
.secondary-btn::after,
.ghost-btn::after,
.small-primary::after { border: none !important; }

.small-primary {
  min-width: 144rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  padding: 0 22rpx;
}

.error-banner {
  margin: 0 24rpx 20rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab-nav {
  margin: 0 24rpx 20rpx;
  height: 84rpx;
  padding: 8rpx;
  background: #ffffff;
  border-radius: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  box-shadow: 0 6rpx 18rpx rgba(91, 108, 255, 0.08);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #8a96a8;
  font-size: 26rpx;
  transition: all 0.25s;
}

.tab-item.active {
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.3);
}

.list {
  padding: 0 24rpx 36rpx;
}

.commission-card {
  position: relative;
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.08);
  overflow: hidden;
}

.commission-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #5b6cff, #f5b041);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.card-meta,
.acceptance-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.status {
  flex: 0 0 auto;
  min-width: 108rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  background: #e2e8f0;
  text-align: center;
}

.status-recruiting {
  color: #166534;
  background: #dcfce7;
}

.status-in_progress,
.status-accepted {
  color: #3a4cd1;
  background: #eef0ff;
}

.status-completed {
  color: #92580d;
  background: #fef3df;
}

.status-resolved,
.status-rewarded {
  color: #5b21b6;
  background: #ede9fe;
}

.desc {
  display: block;
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #445166;
  white-space: pre-wrap;
}

.info-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.info-item {
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #eef0ff, #fef3df);
  min-width: 0;
  text-align: center;
}

.info-label {
  display: block;
  font-size: 21rpx;
  color: #4a5577;
}

.info-value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #3a4cd1;
  word-break: break-all;
}

.card-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.card-actions button {
  margin: 0;
  min-width: 184rpx;
}

.acceptance-list {
  margin-top: 22rpx;
  border-top: 1rpx solid #edf2f7;
}

.acceptance-item {
  padding: 20rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.receiver {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: #334155;
}

.no-acceptance {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
  color: #8a96a8;
  font-size: 25rpx;
}

.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #7b8794;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #475569;
}

.empty-text {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.5;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
}

.modal {
  width: 100%;
  max-height: 88vh;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  animation: slide-up 0.3s ease;
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal.small {
  max-height: 56vh;
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  line-height: 60rpx;
  border-radius: 50%;
  color: #64748b;
  background: #edf2f7;
}

.form {
  margin-top: 24rpx;
}

.field {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 25rpx;
  color: #475569;
  font-weight: 700;
}

.field input,
.field textarea,
.reward-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f4f6fb;
  color: #1a1f3a;
  font-size: 27rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.field input,
.reward-input {
  height: 80rpx;
  padding: 0 20rpx;
}

.field textarea {
  min-height: 180rpx;
  padding: 18rpx 20rpx;
}

.counter,
.hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-actions button {
  margin: 0;
}

.reward-box {
  margin-top: 28rpx;
}

.reward-name {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #334155;
}


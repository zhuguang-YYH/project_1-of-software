.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.chat-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.error-banner {
  margin: 16rpx 24rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
}

.error-retry {
  background: transparent;
  color: #be123c;
  border: 1rpx solid #fecdd3;
  font-size: 22rpx;
}

.message-list {
  flex: 1;
  height: calc(100vh - 190rpx);
  padding: 24rpx 20rpx;
  box-sizing: border-box;
}

.load-more-hint {
  text-align: center;
  padding: 12rpx 0 20rpx;
}

.load-more-hint text {
  font-size: 22rpx;
  color: #c5cee0;
}

.message-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 28rpx;
  align-items: flex-start;
}

.message-row.from-me {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f5;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(91, 108, 255, 0.12);
}

.my-avatar {
  background: linear-gradient(135deg, #5b6cff, #f5b041);
  display: flex;
  align-items: center;
  justify-content: center;
}

.my-avatar-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.bubble-wrap {
  max-width: 70%;
  min-width: 0;
}

.message-row.from-me .bubble-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

.from-friend .text-bubble {
  color: #1a1f3a;
  background: #ffffff;
  border-top-left-radius: 6rpx;
  box-shadow: 0 6rpx 18rpx rgba(91, 108, 255, 0.08);
}

.from-me .text-bubble {
  color: #ffffff;
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  border-top-right-radius: 6rpx;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.25);
}

.game-invite-bubble {
  padding: 0 !important;
  background: #ffffff !important;
  border-radius: 18rpx !important;
  overflow: hidden;
  box-shadow: 0 6rpx 18rpx rgba(91, 108, 255, 0.1);
  min-width: 360rpx;
}

.from-me .game-invite-bubble {
  border-top-right-radius: 6rpx !important;
}

.from-friend .game-invite-bubble {
  border-top-left-radius: 6rpx !important;
}

.gi-card {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.gi-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.gi-icon {
  font-size: 32rpx;
}

.gi-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #f5b041;
  background: #fff8e1;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.gi-game-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1f3a;
}

.gi-message {
  font-size: 24rpx;
  color: #4a5577;
  font-style: italic;
  line-height: 1.5;
}

.gi-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.gi-btn {
  flex: 1;
  padding: 14rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.gi-btn.accept {
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #fff;
}

.gi-btn.decline {
  background: #f5f5f5;
  color: #9aa3b8;
}

.gi-responded {
  margin-top: 6rpx;
  padding: 10rpx 0;
}

.gi-responded-text {
  font-size: 24rpx;
  color: #9aa3b8;
  font-weight: 500;
}

.message-meta {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #8a96a8;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-right {
  justify-content: flex-end;
}

.meta-status {
  color: #c5cee0;
}

.meta-status.failed {
  color: #e74c3c;
  text-decoration: underline;
}

.composer {
  width: 100%;
  padding: 14rpx 16rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f3f8;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 16rpx rgba(91, 108, 255, 0.06);
}

.composer-plus {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #f4f6fb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 36rpx;
  font-weight: 300;
  color: #5b6cff;
  transition: all 0.2s;
}

.composer-plus.active {
  background: #eef0ff;
  transform: rotate(45deg);
}

.message-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #f4f6fb;
  color: #1a1f3a;
  font-size: 27rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #c5cee0;
}

.send-btn {
  width: 120rpx !important;
  min-width: 0;
  height: 80rpx;
  line-height: 1.2;
  border-radius: 14rpx;
  color: #ffffff;
  background: #5b6cff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0 !important;
  margin: 0 !important;
  box-sizing: border-box;
  flex-shrink: 0;
}

.send-btn[disabled] {
  background: #5b6cff !important;
  color: #ffffff !important;
  opacity: 0.5;
}

.send-btn-text {
  color: inherit;
  font-size: inherit;
  font-weight: inherit;
  line-height: 1.2;
}

.invite-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.invite-panel {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow-y: auto;
  animation: slide-up 0.3s ease;
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.invite-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx 16rpx;
  position: sticky;
  top: 0;
  background: #fff;
  z-index: 1;
}

.invite-panel-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1a1f3a;
}

.invite-panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f4f6fb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9aa3b8;
}

.invite-panel-body {
  padding: 0 28rpx 20rpx;
}

.invite-section {
  margin-bottom: 24rpx;
}

.invite-section-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #4a5577;
  margin-bottom: 14rpx;
}

.game-type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.game-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  background: #f4f6fb;
  border: 2rpx solid transparent;
  min-width: 126rpx;
  transition: all 0.2s;
}

.game-type-item.selected {
  background: #eef0ff;
  border-color: #5b6cff;
  box-shadow: 0 4rpx 12rpx rgba(91, 108, 255, 0.15);
}

.game-type-icon {
  font-size: 40rpx;
}

.game-type-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4a5577;
}

.game-type-item.selected .game-type-label {
  color: #5b6cff;
}

.invite-input {
  width: 100%;
  height: 80rpx;
  background: #f4f6fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1f3a;
  box-sizing: border-box;
}

.invite-textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f4f6fb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #1a1f3a;
  box-sizing: border-box;
}

.invite-placeholder {
  color: #c5cee0;
}

.invite-panel-footer {
  padding: 16rpx 28rpx 48rpx;
}

.invite-send-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(91, 108, 255, 0.3);
}

.invite-send-btn::after { border: none; }

.invite-send-btn[disabled] {
  opacity: 0.6;
}

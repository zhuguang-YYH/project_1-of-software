.container {
  min-height: 100vh;
  padding-bottom: 80rpx;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 60%, #fef3df 100%);
}

.conv-header {
  padding: 20rpx 28rpx 10rpx;
}

.conv-header-text {
  font-size: 24rpx;
  color: #9aa3b8;
  font-weight: 500;
}

.conversation-list {
  display: flex;
  flex-direction: column;
  padding: 0 24rpx;
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  gap: 20rpx;
  background: #fff;
  border-radius: 14rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 12rpx rgba(91, 108, 255, 0.05);
}

.conversation-item:active {
  background: #f8f9ff;
}

.conv-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.conv-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f5;
  border: 2rpx solid #eef0ff;
}

.conv-unread-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 6rpx rgba(231, 76, 60, 0.35);
}

.conv-body {
  flex: 1;
  min-width: 0;
}

.conv-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.conv-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1f3a;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conv-time {
  font-size: 22rpx;
  color: #c5cee0;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.conv-bottom-row {
  display: flex;
}

.conv-preview {
  font-size: 24rpx;
  color: #9aa3b8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.conv-preview.unread {
  color: #1a1f3a;
  font-weight: 500;
}

.conv-arrow {
  font-size: 36rpx;
  color: #d0d5e0;
  flex-shrink: 0;
}

/* ========== 好友请求 ========== */
.friend-requests-section {
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(91, 108, 255, 0.05);
}

.fr-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.fr-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e74c3c;
}

.fr-section-count {
  font-size: 22rpx;
  color: #9aa3b8;
}

.fr-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.fr-item + .fr-item {
  border-top: 1rpx solid #f8f9fc;
}

.fr-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f5;
  flex-shrink: 0;
}

.fr-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.fr-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1f3a;
}

.fr-message {
  font-size: 22rpx;
  color: #4a5577;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fr-time {
  font-size: 20rpx;
  color: #c5cee0;
}

.fr-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}

.fr-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.fr-btn.accept {
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #fff;
}

.fr-btn.decline {
  background: #f5f5f5;
  color: #9aa3b8;
}

.page-footer {
  text-align: center;
  padding: 48rpx;
  font-size: 22rpx;
  color: #9aa3b8;
}

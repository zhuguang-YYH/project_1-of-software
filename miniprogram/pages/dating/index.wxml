<view class="page theme-{{theme}} {{a11yFontClass}}">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 聊天主体 -->
  <view class="chat-shell" wx:else>
    <!-- 错误横幅 -->
    <view class="error-banner" wx:if="{{error}}">
      <text>{{error}}</text>
      <button class="error-retry" size="mini" bindtap="onRetry">重试</button>
    </view>

    <!-- 消息列表 -->
    <scroll-view
      class="message-list"
      scroll-y
      scroll-with-animation
      scroll-into-view="{{scroll_into_view}}"
      refresher-enabled="{{true}}"
      refresher-triggered="{{false}}"
      bindrefresherrefresh="onPullDownRefresh"
      bindscrolltoupper="onReachTop"
      upper-threshold="80"
    >
      <!-- 加载更多提示 -->
      <view class="load-more-hint" wx:if="{{has_more}}">
        <text>向上滑动加载更多</text>
      </view>

      <view
        class="message-row {{item.is_me ? 'from-me' : 'from-friend'}}"
        wx:for="{{messages}}"
        wx:key="message_id"
        id="msg-{{item.message_id}}"
      >
        <!-- 好友头像（仅对方消息显示） -->
        <image
          wx:if="{{!item.is_me}}"
          class="msg-avatar"
          src="{{other_user.avatar_url || '/images/icons/avatar.png'}}"
          mode="aspectFill"
          lazy-load="{{true}}"
        />

        <!-- 气泡区域 -->
        <view class="bubble-wrap">
          <!-- 文本消息 -->
          <view class="bubble text-bubble" wx:if="{{item.content_type === 'text'}}">
            <text>{{item.content}}</text>
          </view>

          <!-- 游戏邀请卡片 -->
          <view class="bubble game-invite-bubble" wx:if="{{item.content_type === 'game_invite'}}">
            <view class="gi-card">
              <view class="gi-top">
                <text class="gi-icon">{{item.game_data.game_type === 'script_kill' ? '🎭' : item.game_data.game_type === 'board_game' ? '🎲' : item.game_data.game_type === 'puzzle' ? '🧩' : item.game_data.game_type === 'activity' ? '🎪' : '🎯'}}</text>
                <text class="gi-label">游戏邀请</text>
              </view>
              <text class="gi-game-name">{{item.game_data.game_name}}</text>
              <text class="gi-message" wx:if="{{item.game_data.message}}">"{{item.game_data.message}}"</text>
              <!-- 接收方操作按钮 -->
              <view class="gi-actions" wx:if="{{!item.is_me && !item.game_data.responded}}">
                <view class="gi-btn accept" data-msg-id="{{item.message_id}}" data-action="accept" bindtap="respondGameInvite">
                  <text>✓ 接受</text>
                </view>
                <view class="gi-btn decline" data-msg-id="{{item.message_id}}" data-action="decline" bindtap="respondGameInvite">
                  <text>✕ 拒绝</text>
                </view>
              </view>
              <!-- 已响应状态 -->
              <view class="gi-responded" wx:if="{{item.game_data.responded}}">
                <text class="gi-responded-text">{{item.game_data.responded === 'accept' ? '✅ 已接受' : '❌ 已拒绝'}}</text>
              </view>
            </view>
          </view>

          <!-- 时间 & 状态 -->
          <view class="message-meta {{item.is_me ? 'meta-right' : ''}}">
            <text class="meta-time">{{item.time_text}}</text>
            <text wx:if="{{item._pending}}" class="meta-status">发送中...</text>
            <text wx:elif="{{item._failed}}" class="meta-status failed" data-msg-id="{{item.message_id}}" bindtap="retryMessage">发送失败 · 点击重试</text>
          </view>
        </view>

        <!-- 我的头像（仅自己消息显示） -->
        <view wx:if="{{item.is_me}}" class="msg-avatar my-avatar">
          <text class="my-avatar-text">我</text>
        </view>
      </view>
    </scroll-view>

    <!-- 输入栏 -->
    <view class="composer">
      <view class="composer-plus {{show_invite_panel ? 'active' : ''}}" bindtap="toggleInvitePanel">
        <text>+</text>
      </view>
      <input
        class="message-input"
        value="{{input_value}}"
        placeholder="输入消息..."
        placeholder-class="input-placeholder"
        confirm-type="send"
        maxlength="500"
        adjust-position="{{true}}"
        cursor-spacing="16"
        bindinput="onInput"
        bindconfirm="sendMessage"
      />
      <button class="send-btn" disabled="{{sending || input_value === ''}}" bindtap="sendMessage">
        <text class="send-btn-text">发送</text>
      </button>
    </view>

    <!-- 游戏邀请面板 -->
    <view class="invite-overlay" wx:if="{{show_invite_panel}}" catchtouchmove="noop">
      <view class="invite-panel">
        <view class="invite-panel-header">
          <text class="invite-panel-title">发送游戏邀请</text>
          <view class="invite-panel-close" bindtap="toggleInvitePanel">✕</view>
        </view>

        <view class="invite-panel-body">
          <!-- 游戏类型 -->
          <view class="invite-section">
            <text class="invite-section-label">游戏类型</text>
            <view class="game-type-grid">
              <view
                class="game-type-item {{invite_game_type === item.key ? 'selected' : ''}}"
                wx:for="{{gameTypes}}"
                wx:key="key"
                data-type="{{item.key}}"
                bindtap="selectGameType"
              >
                <text class="game-type-icon">{{item.icon}}</text>
                <text class="game-type-label">{{item.label}}</text>
              </view>
            </view>
          </view>

          <!-- 游戏名称 -->
          <view class="invite-section">
            <text class="invite-section-label">游戏名称（选填）</text>
            <input
              class="invite-input"
              value="{{invite_game_name}}"
              placeholder="如：窗边的女人、年轮..."
              placeholder-class="invite-placeholder"
              maxlength="40"
              bindinput="onInviteGameNameInput"
            />
          </view>

          <!-- 附言 -->
          <view class="invite-section">
            <text class="invite-section-label">附言（选填）</text>
            <textarea
              class="invite-textarea"
              value="{{invite_message}}"
              placeholder="说点什么吧..."
              placeholder-class="invite-placeholder"
              maxlength="200"
              show-confirm-bar="{{false}}"
              bindinput="onInviteMessageInput"
            />
          </view>
        </view>

        <view class="invite-panel-footer">
          <button class="invite-send-btn" loading="{{invite_sending}}" disabled="{{invite_sending}}" bindtap="sendGameInvite">
            发送邀请
          </button>
        </view>
      </view>
    </view>
  </view>
</view>

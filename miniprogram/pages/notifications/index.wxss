.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
}

.page-body {
  padding: 0 24rpx;
}

.error-banner {
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #fee2e2;
  color: #991b1b;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.notif-header {
  margin: 24rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.notif-title-text {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #1a1f3a;
}

.notif-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #8a96a8;
}

.mark-all-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  font-size: 26rpx;
  line-height: 1.2;
  color: #5b6cff;
  background: transparent;
  border: none;
  padding: 8rpx 16rpx;
}

.mark-all-btn::after {
  border: none;
}

.notif-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 60rpx;
}

.notif-card {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(91, 108, 255, 0.06);
  position: relative;
  transition: all 0.2s;
}

.notif-card.unread {
  background: #fafbff;
  border-left: 6rpx solid #5b6cff;
}

.notif-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  width: 56rpx;
  text-align: center;
}

.notif-body {
  flex: 1;
  min-width: 0;
}

.notif-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.notif-card-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1a1f3a;
  flex: 1;
}

.notif-time {
  font-size: 23rpx;
  line-height: 1.35;
  color: #8a96a8;
  flex-shrink: 0;
}

.notif-content {
  display: block;
  font-size: 27rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notif-dot {
  position: absolute;
  top: 28rpx;
  right: 24rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e74c3c;
}

.notif-empty {
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.notif-empty-icon {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #eef0ff, #e0e4ff);
  font-size: 66rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.12);
}

.notif-empty-title {
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #1a1f3a;
}

.notif-empty-desc {
  margin-top: 14rpx;
  max-width: 520rpx;
  font-size: 27rpx;
  line-height: 1.55;
  color: #64748b;
}

/* 黑金主题 */
.theme-gold.page {
  background:
    radial-gradient(circle at 92% 2%, rgba(212, 175, 55, 0.18) 0%, transparent 36%),
    linear-gradient(135deg, #0a0a0a 0%, #161616 48%, #202020 100%);
}

.theme-gold .notif-title-text {
  color: #f8e7a8;
}

.theme-gold .notif-desc {
  color: rgba(244, 236, 214, 0.78);
}

.theme-gold .mark-all-btn {
  color: #f8e7a8;
}

.theme-gold .notif-card {
  background: #171717;
  border: 1rpx solid rgba(212, 175, 55, 0.16);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.24);
}

.theme-gold .notif-card.unread {
  background: #1a1810;
  border-left: 6rpx solid #d4af37;
}

.theme-gold .notif-card-title {
  color: #f8e7a8;
}

.theme-gold .notif-content {
  color: rgba(244, 236, 214, 0.82);
}

.theme-gold .notif-time {
  color: rgba(244, 236, 214, 0.66);
}

.theme-gold .notif-empty-icon {
  background: linear-gradient(135deg, #292111, #d4af37);
  color: #fff6d6;
  box-shadow: 0 12rpx 32rpx rgba(212, 175, 55, 0.24);
}

.theme-gold .notif-empty-title {
  color: #f8e7a8;
}

.theme-gold .notif-empty-desc {
  color: rgba(244, 236, 214, 0.82);
}

<view class="container" wx:if="{{!loading}}">
  <view class="login-card" wx:if="{{!userInfo}}">
    <image class="login-avatar" src="/images/icons/avatar.png" />
    <text class="login-title">建立侦探档案</text>
    <text class="login-desc">登录后可保存积分、排行榜、委托和个人名片信息。</text>
    <button class="login-btn" bindtap="loginAndEdit">登录并完善资料</button>
  </view>

  <view class="profile-header" wx:if="{{userInfo}}">
    <view class="header-bg"></view>

    <view class="user-card" wx:if="{{!editMode}}">
      <view class="avatar-area">
        <image class="user-avatar{{profileIncomplete ? ' user-avatar--incomplete' : ''}}" src="{{userInfo.avatar_url || '/images/icons/avatar.png'}}" />
      </view>
      <view class="user-info">
        <text class="user-name{{profileIncomplete ? ' user-name--dim' : ''}}">{{userInfo.nickname || '待完善昵称'}}</text>
        <text class="user-signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</text>
        <text class="user-id">编号 #{{userIdShort}}</text>
        <view class="interest-tags" wx:if="{{interestList.length}}">
          <text class="interest-tag" wx:for="{{interestList}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="incomplete-nudge" wx:if="{{profileIncomplete}}">
          <text class="nudge-text">完善档案后信息更完整</text>
        </view>
      </view>
      <view class="card-edit-btn" bindtap="startEdit" hover-class="card-edit-btn--tap">
        {{profileIncomplete ? '去完善' : '编辑'}}
      </view>
    </view>

    <view class="edit-form" wx:if="{{editMode}}">
      <view class="edit-avatar-section">
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="user-avatar" src="{{form.avatar_url || '/images/icons/avatar.png'}}" />
          <view class="avatar-edit-badge">换</view>
        </button>
        <text class="edit-avatar-hint">点击头像可更换</text>
      </view>
      <view class="form-field">
        <text class="form-label">昵称</text>
        <input class="form-input" value="{{form.nickname}}" placeholder="请输入昵称" type="nickname" data-field="nickname" bindinput="onInput" />
      </view>
      <view class="form-field">
        <text class="form-label">个性签名</text>
        <textarea class="form-textarea" auto-height value="{{form.signature}}" placeholder="一句侦探签名（选填）" data-field="signature" bindinput="onInput" maxlength="80" show-confirm-bar="{{false}}" />
      </view>
      <view class="form-field">
        <text class="form-label">兴趣标签</text>
        <input class="form-input" value="{{form.interests}}" placeholder="多个标签用顿号 、 分隔" data-field="interests" bindinput="onInput" />
      </view>
      <view class="form-actions">
        <button class="form-save-btn" loading="{{savingProfile}}" disabled="{{savingProfile}}" bindtap="saveEdit">保存档案</button>
        <button class="form-cancel-btn" bindtap="cancelEdit">取消</button>
      </view>
    </view>

    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-label">可兑换积分</text>
        <text class="stat-value">{{myPoints}}</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">当前排名</text>
        <text class="stat-value">{{myRank > 100 ? '未入榜' : '第 ' + myRank + ' 名'}}</text>
      </view>
    </view>
  </view>

  <view class="quick-menu" wx:if="{{userInfo}}">
    <view class="menu-item tap-feedback" bindtap="goToActivity">
      <view class="icon-circle is-gold">动</view>
      <text class="menu-text">活动报名</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" bindtap="goBorrow">
      <view class="icon-circle is-cyan">借</view>
      <text class="menu-text">物资借阅</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" bindtap="goExchange">
      <view class="icon-circle is-success">兑</view>
      <text class="menu-text">积分兑换</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" bindtap="goPoints">
      <view class="icon-circle is-purple">分</view>
      <text class="menu-text">积分明细</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" bindtap="goCommission">
      <view class="icon-circle is-orange">委</view>
      <text class="menu-text">事件委托</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" bindtap="goFeedback">
      <view class="icon-circle is-pink">馈</view>
      <text class="menu-text">反馈建议</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" bindtap="goSettings">
      <view class="icon-circle">设</view>
      <text class="menu-text">系统设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item tap-feedback" wx:if="{{userInfo.role === 'admin'}}" bindtap="goAdmin">
      <view class="icon-circle is-gold">管</view>
      <text class="menu-text">管理后台</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="about-section" wx:if="{{userInfo}}">
    <view class="about-header">
      <text class="about-title">关于</text>
    </view>
    <view class="about-content">
      <text class="about-text">NK推协侦探管理系统</text>
      <text class="about-desc">让每位侦探都能享受推理的乐趣。</text>
    </view>
  </view>
</view>

<view class="loading-state" wx:elif="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

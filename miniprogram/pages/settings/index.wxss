.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
  color: #1a1f3a;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.account-panel {
  position: relative;
  margin: 24rpx;
  padding: 36rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1a1f3a 0%, #3a4cd1 100%);
  box-shadow: 0 16rpx 40rpx rgba(91, 108, 255, 0.28);
  color: #fff;
  overflow: hidden;
}

.account-panel::before {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(245, 176, 65, 0.18);
  top: -70rpx;
  right: -50rpx;
  pointer-events: none;
}

.section {
  margin: 0 24rpx 20rpx;
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.06);
}

.panel-title,
.section-title {
  display: block;
  padding: 18rpx 0 14rpx;
  position: relative;
  padding-left: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1f3a;
}

.account-panel .panel-title {
  color: rgba(255,255,255,0.78);
  padding-left: 0;
  letter-spacing: 2rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.account-panel .panel-title::before { display: none; }

.section .section-title::before {
  content: '';
  position: absolute;
  left: 0; top: 22rpx;
  width: 8rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #5b6cff, #f5b041);
}

.account-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255,255,255,0.2);
}

.account-meta {
  flex: 1;
  min-width: 0;
}

.account-name {
  display: block;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
}

.account-role {
  display: block;
  margin-top: 6rpx;
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
}

.setting-row,
.action-row {
  min-height: 110rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 1rpx solid #f0f3f8;
}

.setting-row:last-child,
.action-row:last-child {
  border-bottom: 0;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  padding: 8rpx 0 24rpx;
}

.theme-option {
  position: relative;
  min-height: 190rpx;
  border-radius: 18rpx;
  padding: 18rpx;
  border: 2rpx solid #e2e6f3;
  background: #f8fafc;
  overflow: hidden;
}

.theme-option.active {
  border-color: #5b6cff;
  box-shadow: 0 10rpx 24rpx rgba(91, 108, 255, 0.14);
}

.theme-preview {
  height: 92rpx;
  border-radius: 14rpx;
  padding: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.theme-blue .theme-preview {
  background: linear-gradient(135deg, #3a4cd1 0%, #5b6cff 65%, #6c5bff 100%);
}

.theme-gold .theme-preview {
  background:
    radial-gradient(circle at 90% 0%, rgba(212, 175, 55, 0.24), transparent 46%),
    linear-gradient(135deg, #0a0a0a 0%, #171717 58%, #252019 100%);
}

.theme-preview-bar {
  width: 84rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.theme-gold .theme-preview-bar {
  background: #d4af37;
}

.theme-preview-line {
  margin-top: 14rpx;
  width: 120rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
}

.theme-preview-line.short {
  width: 74rpx;
}

.theme-copy {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.theme-name {
  color: #1a1f3a;
  font-size: 26rpx;
  font-weight: 800;
}

.theme-desc {
  color: #8a96a8;
  font-size: 22rpx;
}

.theme-check {
  position: absolute;
  top: 14rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #5b6cff;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-option.theme-gold.active {
  border-color: #d4af37;
  box-shadow: 0 10rpx 24rpx rgba(212, 175, 55, 0.18);
}

.theme-option.theme-gold .theme-check {
  background: #d4af37;
  color: #17110a;
}

.action-row {
  transition: background 0.15s;
}

.action-row:active {
  background: #f4f6fb;
  border-radius: 12rpx;
  margin: 0 -16rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.setting-name {
  display: block;
  color: #1a1f3a;
  font-size: 28rpx;
  font-weight: 700;
}

.setting-desc {
  display: block;
  margin-top: 6rpx;
  color: #8a96a8;
  font-size: 23rpx;
  line-height: 1.4;
}

.arrow {
  flex: 0 0 auto;
  color: #c0c8d2;
  font-size: 40rpx;
}

.danger .setting-name {
  color: #e74c3c;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

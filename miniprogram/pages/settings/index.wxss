.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
  color: #1a1f3a;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.account-panel {
  position: relative;
  margin: 24rpx;
  padding: 36rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1a1f3a 0%, #3a4cd1 100%);
  box-shadow: 0 16rpx 40rpx rgba(91, 108, 255, 0.28);
  color: #fff;
  overflow: hidden;
}

.account-panel::before {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(245, 176, 65, 0.18);
  top: -70rpx;
  right: -50rpx;
  pointer-events: none;
}

.section {
  margin: 0 24rpx 20rpx;
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.06);
}

.panel-title,
.section-title {
  display: block;
  padding: 18rpx 0 14rpx;
  position: relative;
  padding-left: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1f3a;
}

.account-panel .panel-title {
  color: rgba(255,255,255,0.78);
  padding-left: 0;
  letter-spacing: 2rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.account-panel .panel-title::before { display: none; }

.section .section-title::before {
  content: '';
  position: absolute;
  left: 0; top: 22rpx;
  width: 8rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #5b6cff, #f5b041);
}

.account-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255,255,255,0.2);
}

.account-meta {
  flex: 1;
  min-width: 0;
}

.account-name {
  display: block;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
}

.account-role {
  display: block;
  margin-top: 6rpx;
  color: rgba(255,255,255,0.78);
  font-size: 24rpx;
}

.setting-row,
.action-row {
  min-height: 110rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 1rpx solid #f0f3f8;
}

.setting-row:last-child,
.action-row:last-child {
  border-bottom: 0;
}

.action-row {
  transition: background 0.15s;
}

.action-row:active {
  background: #f4f6fb;
  border-radius: 12rpx;
  margin: 0 -16rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.setting-name {
  display: block;
  color: #1a1f3a;
  font-size: 28rpx;
  font-weight: 700;
}

.setting-desc {
  display: block;
  margin-top: 6rpx;
  color: #8a96a8;
  font-size: 23rpx;
  line-height: 1.4;
}

.arrow {
  flex: 0 0 auto;
  color: #c0c8d2;
  font-size: 40rpx;
}

.danger .setting-name {
  color: #e74c3c;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

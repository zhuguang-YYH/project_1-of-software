<view class="page" wx:if="{{!loading}}">
  <scroll-view class="scroll-view" scroll-y>
    <view class="account-panel">
      <text class="panel-title">登录状态</text>
      <view class="account-row">
        <image class="avatar" src="{{userInfo.avatar_url || '/images/icons/avatar.png'}}" />
        <view class="account-meta">
          <text class="account-name">{{userInfo.nickname || '未登录'}}</text>
          <text class="account-role">{{userInfo.role === 'admin' ? '管理员' : (userInfo ? '普通用户' : '游客')}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <text class="section-title">通知提醒</text>
      <view class="setting-row">
        <view>
          <text class="setting-name">每日谜题提醒</text>
          <text class="setting-desc">保留本地偏好，后续可接入订阅消息。</text>
        </view>
        <switch checked="{{settings.puzzle_reminder}}" data-field="puzzle_reminder" bindchange="onSettingChange" />
      </view>
      <view class="setting-row">
        <view>
          <text class="setting-name">活动报名提醒</text>
          <text class="setting-desc">用于活动开始、报名截止等提醒。</text>
        </view>
        <switch checked="{{settings.activity_reminder}}" data-field="activity_reminder" bindchange="onSettingChange" />
      </view>
      <view class="setting-row">
        <view>
          <text class="setting-name">借阅状态提醒</text>
          <text class="setting-desc">用于传递、借出、归还状态变化。</text>
        </view>
        <switch checked="{{settings.borrow_reminder}}" data-field="borrow_reminder" bindchange="onSettingChange" />
      </view>
      <view class="setting-row">
        <view>
          <text class="setting-name">委托进度提醒</text>
          <text class="setting-desc">用于领取、完成、奖励分配变化。</text>
        </view>
        <switch checked="{{settings.commission_reminder}}" data-field="commission_reminder" bindchange="onSettingChange" />
      </view>
    </view>

    <view class="section">
      <text class="section-title">隐私与显示</text>
      <view class="setting-row">
        <view>
          <text class="setting-name">展示排行榜身份</text>
          <text class="setting-desc">关闭后后续排行榜可按匿名展示处理。</text>
        </view>
        <switch checked="{{settings.show_ranking}}" data-field="show_ranking" bindchange="onSettingChange" />
      </view>
      <view class="setting-row">
        <view>
          <text class="setting-name">允许展示个人名片</text>
          <text class="setting-desc">用于从排行榜或委托页查看名片。</text>
        </view>
        <switch checked="{{settings.show_profile_card}}" data-field="show_profile_card" bindchange="onSettingChange" />
      </view>
      <view class="setting-row">
        <view>
          <text class="setting-name">紧凑显示模式</text>
          <text class="setting-desc">为信息密集页面预留偏好。</text>
        </view>
        <switch checked="{{settings.compact_mode}}" data-field="compact_mode" bindchange="onSettingChange" />
      </view>
    </view>

    <view class="section">
      <text class="section-title">缓存与安全</text>
      <view class="action-row" bindtap="clearCache">
        <view>
          <text class="setting-name">清理本地缓存</text>
          <text class="setting-desc">当前约 {{cacheText}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-row danger" wx:if="{{userInfo}}" bindtap="logout">
        <view>
          <text class="setting-name">退出登录</text>
          <text class="setting-desc">清理本地登录状态。</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="section" wx:if="{{userInfo.role === 'admin'}}">
      <text class="section-title">管理员</text>
      <view class="action-row" bindtap="goAdmin">
        <view>
          <text class="setting-name">系统参数维护</text>
          <text class="setting-desc">进入后台设置页。</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </scroll-view>
</view>

<view class="loading-state" wx:else>
  <view class="loading-spinner"></view>
  <text>加载设置中...</text>
</view>

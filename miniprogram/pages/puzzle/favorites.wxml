<common-loading visible="{{loading}}" title="加载收藏..." mask="{{false}}" />

<view class="container theme-{{theme}} {{a11yFontClass}}" wx:if="{{!loading}}">
  <!-- 错误状态 -->
  <empty-state
    wx:if="{{error && puzzles.length === 0}}"
    theme="{{theme}}"
    icon="!"
    title="{{error}}"
    description="请检查网络后重试"
    action-text="重试"
    bind:action="initPage"
  />

  <!-- 收藏列表 -->
  <view class="fav-list" wx:elif="{{puzzles.length > 0}}">
    <view class="fav-header">
      <text class="fav-count">共 {{total}} 道收藏</text>
    </view>

    <view
      class="fav-item tap-feedback"
      wx:for="{{puzzles}}"
      wx:key="puzzle_id"
    >
      <view class="fav-info" data-puzzle-id="{{item.puzzle_id}}" bindtap="goToPractice">
        <view class="fav-tags">
          <text class="card-category">{{item.category || '未分类'}}</text>
          <text class="card-difficulty difficulty-{{item._difficulty_class}}">{{item._difficulty_text}}</text>
        </view>
        <text class="fav-title">{{item.title || item.content}}</text>
        <view class="fav-meta">
          <text class="meta-text">正确率 {{item.correct_rate}}%</text>
          <text class="meta-text">{{item.attempt_count}} 人答过</text>
        </view>
      </view>
      <view class="fav-actions">
        <view class="fav-remove tap-feedback" data-puzzle-id="{{item.puzzle_id}}" bindtap="removeFavorite">
          <text>✕</text>
        </view>
        <text class="fav-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:elif="{{!error && puzzles.length === 0}}"
    theme="{{theme}}"
    icon="☆"
    title="暂无收藏"
    description="浏览谜题库，收藏你喜欢的谜题吧"
    action-text="去谜题库"
    bind:action="goToBank"
  />

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && puzzles.length > 0}}">
    <text class="load-more-text" wx:if="{{!loading_more}}" bindtap="loadMore">加载更多</text>
    <text class="load-more-text loading" wx:else>加载中...</text>
  </view>

  <view class="no-more" wx:elif="{{!hasMore && puzzles.length > 0}}">
    <text class="no-more-text">— 已显示全部收藏 —</text>
  </view>
</view>

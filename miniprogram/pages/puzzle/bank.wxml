<common-loading visible="{{loading}}" title="加载谜题库..." mask="{{false}}" />

<view class="container theme-{{theme}} {{a11yFontClass}}" wx:if="{{!loading}}">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索谜题..."
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 分类横向筛选 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      class="filter-chip {{activeCategory === '' ? 'active' : ''}}"
      bindtap="onCategoryFilter"
      data-category=""
    >全部</view>
    <view
      class="filter-chip {{activeCategory === item.value ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="value"
      wx:if="{{item.count > 0}}"
      bindtap="onCategoryFilter"
      data-category="{{item.value}}"
    >{{item.label}} ({{item.count}})</view>
  </scroll-view>

  <!-- 难度和排序 -->
  <view class="toolbar">
    <view class="difficulty-row">
      <view
        class="diff-chip {{activeDifficulty === '' ? 'active' : ''}}"
        bindtap="onDifficultyFilter"
        data-difficulty=""
      >全部难度</view>
      <view
        class="diff-chip {{activeDifficulty === 'easy' ? 'active' : ''}}"
        bindtap="onDifficultyFilter"
        data-difficulty="easy"
      >简单</view>
      <view
        class="diff-chip {{activeDifficulty === 'normal' ? 'active' : ''}}"
        bindtap="onDifficultyFilter"
        data-difficulty="normal"
      >中等</view>
      <view
        class="diff-chip {{activeDifficulty === 'hard' ? 'active' : ''}}"
        bindtap="onDifficultyFilter"
        data-difficulty="hard"
      >困难</view>
      <view
        class="diff-chip {{activeDifficulty === 'extreme' ? 'active' : ''}}"
        bindtap="onDifficultyFilter"
        data-difficulty="extreme"
      >极限</view>
    </view>

    <view class="sort-row">
      <view class="sort-chip {{sortBy === 'date' && sortOrder === 'desc' ? 'active' : ''}}" bindtap="onSortChange" data-sort="date:desc">最新</view>
      <view class="sort-chip {{sortBy === 'date' && sortOrder === 'asc' ? 'active' : ''}}" bindtap="onSortChange" data-sort="date:asc">最早</view>
      <view class="sort-chip {{sortBy === 'correct_rate' ? 'active' : ''}}" bindtap="onSortChange" data-sort="correct_rate:desc">最高正确率</view>
    </view>
  </view>

  <!-- 收藏入口 -->
  <view class="favorites-entry tap-feedback" bindtap="goToFavorites">
    <text class="fav-icon">★</text>
    <text class="fav-text">我的收藏</text>
    <text class="fav-arrow">›</text>
  </view>

  <!-- 错误状态 -->
  <empty-state
    wx:if="{{error && puzzles.length === 0}}"
    icon="!"
    title="{{error}}"
    description="请检查网络后重试"
    action-text="重试"
    bind:action="initPage"
  />

  <!-- 谜题网格 -->
  <view class="puzzle-grid" wx:elif="{{puzzles.length > 0}}">
    <view
      class="puzzle-card tap-feedback"
      wx:for="{{puzzles}}"
      wx:key="puzzle_id"
      data-puzzle-id="{{item.puzzle_id}}"
      bindtap="goToPractice"
    >
      <view class="card-header">
        <view class="card-tags">
          <text class="card-category category-{{item.category === '逻辑推理' ? 'logic' : item.category === '密码解密' ? 'crypto' : item.category === '字谜' ? 'riddle' : item.category === '数学' ? 'math' : item.category === '观察力' ? 'observe' : 'other'}}">{{item.category || '未分类'}}</text>
          <text class="card-difficulty difficulty-{{item._difficulty_class}}">{{item._difficulty_text}}</text>
        </view>
        <text class="card-favorite {{item.is_favorited ? 'favorited' : ''}}">{{item.is_favorited ? '★' : '☆'}}</text>
      </view>

      <text class="card-title">{{item.title || item.content}}</text>

      <view class="card-meta">
        <text class="meta-stats">正确率 {{item.correct_rate}}%</text>
        <text class="meta-stats">{{item.attempt_count}} 人答过</text>
      </view>

      <view class="card-reward" wx:if="{{item.reward_points}}">
        <text class="reward-icon">💰</text>
        <text class="reward-text">+{{item.reward_points}} 积分</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:elif="{{!error && puzzles.length === 0}}"
    icon="?"
    title="暂无谜题"
    description="{{searchKeyword ? '没有找到匹配的谜题，换个关键词试试' : '该分类下暂无谜题'}}"
    action-text="清除筛选"
    bind:action="initPage"
  />

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && puzzles.length > 0}}">
    <text class="load-more-text" wx:if="{{!loading_more}}" bindtap="loadMore">加载更多</text>
    <text class="load-more-text loading" wx:else>加载中...</text>
  </view>

  <view class="no-more" wx:elif="{{!hasMore && puzzles.length > 0}}">
    <text class="no-more-text">— 共 {{total}} 道谜题 —</text>
  </view>

  <!-- 页脚 -->
  <view class="page-footer">NK推协 · 谜题库</view>
</view>

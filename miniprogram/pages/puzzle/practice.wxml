<common-loading visible="{{loading}}" title="加载谜题中..." mask="{{false}}" />

<view class="container theme-{{theme}} {{a11yFontClass}}" wx:if="{{!loading}}">
  <empty-state
    wx:if="{{error}}"
    icon="!"
    title="{{error}}"
    description="请检查网络后重试"
    action-text="重试"
    bind:action="onRetry"
  />

  <view class="puzzle-card" wx:elif="{{puzzle}}">
    <view class="puzzle-header">
      <view class="puzzle-title-block">
        <text class="puzzle-eyebrow">PRACTICE PUZZLE</text>
        <text class="puzzle-title">谜题练习</text>
      </view>
      <view class="puzzle-header-actions">
        <view class="fav-btn tap-feedback {{is_favorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
          <text>{{is_favorited ? '★' : '☆'}}</text>
        </view>
        <view class="puzzle-difficulty difficulty-{{puzzle._difficulty_class || 'normal'}}">
          <text>{{puzzle._difficulty_text || '中等'}}</text>
        </view>
      </view>
    </view>

    <view class="puzzle-content">
      <text class="puzzle-desc">{{puzzle.content}}</text>
    </view>

    <view class="options-container" wx:if="{{!answered}}">
      <view class="already-notice" wx:if="{{already_answered}}">
        <text>您已经练习过这道谜题了</text>
      </view>
      <view
        class="option {{selected_option_id === item.option_id ? 'selected' : ''}}"
        wx:for="{{options}}"
        wx:key="option_id"
        data-option-id="{{item.option_id}}"
        bindtap="selectOption"
      >
        <view class="option-label">{{item.option_label}}</view>
        <text class="option-text">{{item.option_content}}</text>
      </view>
    </view>

    <view class="answer-display" wx:elif="{{answered}}">
      <view class="answer-status {{is_correct ? 'correct' : 'wrong'}}">
        <text class="status-icon">{{is_correct ? '✓' : '×'}}</text>
        <text class="status-text">{{is_correct ? '恭喜答对！' : '回答错误'}}</text>
      </view>

      <view class="answer-info">
        <text class="info-title">正确答案</text>
        <text class="info-content">{{puzzle.correct_answer}}</text>
      </view>

      <view class="analysis" wx:if="{{puzzle.answer_explanation}}">
        <text class="analysis-title">解析</text>
        <text class="analysis-content">{{puzzle.answer_explanation}}</text>
      </view>
    </view>

    <view class="action-buttons">
      <button
        class="btn btn-submit"
        wx:if="{{!answered}}"
        disabled="{{!selected_option_id || submitting}}"
        bindtap="submitAnswer"
        loading="{{submitting}}"
      >
        {{submitting ? '提交中...' : '提交答案'}}
      </button>
      <button class="btn btn-back" bindtap="goBack">返回</button>
    </view>

    <view class="bank-link tap-feedback" bindtap="goToBank">
      <text>浏览谜题库 →</text>
    </view>
  </view>
</view>

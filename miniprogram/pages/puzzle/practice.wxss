/* pages/puzzle/practice/index.wxss */
/* 复用每日谜题的所有样式 */
@import './index.wxss';

/* 头部操作区 */
.puzzle-header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

/* 收藏按钮 */
.fav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: rgba(255,255,255,0.6);
  transition: all 0.2s;
}

.fav-btn:active {
  transform: scale(0.9);
}

.fav-btn.favorited {
  background: rgba(245, 176, 65, 0.4);
  color: #ffd76b;
}

/* 已答提示 */
.already-notice {
  text-align: center;
  padding: 16rpx;
  background: #fef3df;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #92580d;
}

/* 谜题库链接 */
.bank-link {
  text-align: center;
  padding: 20rpx 32rpx 28rpx;
  font-size: 26rpx;
  color: #5b6cff;
  font-weight: 600;
}

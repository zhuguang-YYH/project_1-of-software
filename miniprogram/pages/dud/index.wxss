.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
  color: #1a1f3a;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.chat-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.error-banner {
  margin: 20rpx 24rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 25rpx;
}

.message-list {
  flex: 1;
  height: calc(100vh - 220rpx);
  padding: 24rpx;
  box-sizing: border-box;
}

.message-row,
.typing {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  align-items: flex-start;
}

.message-row.from-user {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(91, 108, 255, 0.2);
}

.dud-avatar {
  background: linear-gradient(135deg, #1a1f3a, #3a4cd1);
}

.user-avatar {
  background: linear-gradient(135deg, #5b6cff, #f5b041);
}

.bubble-wrap {
  max-width: 74%;
  min-width: 0;
}

.message-row.from-user .bubble-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.bubble,
.typing-bubble {
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

.from-dud .bubble,
.typing-bubble {
  color: #1a1f3a;
  background: #ffffff;
  border-top-left-radius: 6rpx;
  box-shadow: 0 6rpx 18rpx rgba(91, 108, 255, 0.08);
}

.typing-bubble {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.typing-dots {
  display: inline-flex;
  gap: 6rpx;
  align-items: center;
}

.typing-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5b6cff;
  animation: typing-bounce 1.2s infinite ease-in-out;
}

.typing-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing-bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

.from-user .bubble {
  color: #ffffff;
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  border-top-right-radius: 6rpx;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.25);
}

.message-meta {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #8a96a8;
}

.quick-prompts {
  padding: 14rpx 20rpx 14rpx;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  background: transparent;
  box-sizing: border-box;
}

.prompt {
  flex: 0 0 auto;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #3a4cd1;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(91, 108, 255, 0.1);
  border: 1rpx solid rgba(91, 108, 255, 0.15);
}

.composer {
  padding: 16rpx 20rpx 26rpx;
  display: grid;
  grid-template-columns: 1fr 140rpx;
  gap: 14rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f3f8;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 16rpx rgba(91, 108, 255, 0.06);
}

.message-input {
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #f4f6fb;
  color: #1a1f3a;
  font-size: 27rpx;
  box-sizing: border-box;
}

.send-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #5b6cff;
  font-size: 26rpx;
  padding: 0;
}

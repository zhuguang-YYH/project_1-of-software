.page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #243041;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: #64748b;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #dbeafe;
  border-top-color: #2477c3;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.error-banner {
  margin: 24rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fff1f2;
  color: #be123c;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab-nav {
  margin: 24rpx 24rpx 20rpx;
  padding: 6rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  border-radius: 8rpx;
  background: #e8edf3;
}

.tab-item {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #64748b;
}

.tab-item.active {
  background: #ffffff;
  color: #2477c3;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(31, 41, 55, 0.08);
}

.panel,
.list {
  margin: 0 24rpx 36rpx;
}

.panel {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(22, 34, 51, 0.06);
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.type-item {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 24rpx;
}

.type-item.active {
  background: #dbeafe;
  color: #1d4ed8;
  font-weight: 700;
}

.field {
  margin-bottom: 22rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  font-size: 25rpx;
  color: #475569;
  font-weight: 700;
}

.field input,
.field textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #f7f9fc;
  color: #1f2937;
  font-size: 27rpx;
}

.field input {
  height: 80rpx;
  padding: 0 20rpx;
}

.field textarea {
  min-height: 220rpx;
  padding: 18rpx 20rpx;
}

.counter {
  margin-top: 8rpx;
  text-align: right;
  font-size: 22rpx !important;
  color: #8a96a8 !important;
  font-weight: 400 !important;
}

.switch-row {
  margin: 12rpx 0 28rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.switch-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.switch-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.primary-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #2477c3;
  font-size: 27rpx;
}

.feedback-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(22, 34, 51, 0.06);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.card-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #9a3412;
  background: #ffedd5;
  font-size: 22rpx;
}

.status.resolved {
  color: #166534;
  background: #dcfce7;
}

.content {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #475569;
  white-space: pre-wrap;
}

.remark {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
}

.remark-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.remark-text {
  display: block;
  font-size: 25rpx;
  color: #334155;
}

.empty-state {
  padding: 90rpx 32rpx;
  text-align: center;
  color: #7b8794;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #475569;
}

.empty-text {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
}

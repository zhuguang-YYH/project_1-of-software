.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6fb 0%, #eef0ff 100%);
  color: #1a1f3a;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #8a96a8;
  font-size: 26rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #eef0ff;
  border-top-color: #5b6cff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-banner {
  margin: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #fee2e2;
  color: #991b1b;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-left: 6rpx solid #e74c3c;
  gap: 16rpx;
}

.tab-nav {
  margin: 24rpx 24rpx 20rpx;
  padding: 8rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(91, 108, 255, 0.08);
}

.tab-item {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 27rpx;
  color: #8a96a8;
  transition: all 0.25s;
}

.tab-item.active {
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 255, 0.3);
}

.panel,
.list {
  margin: 0 24rpx 36rpx;
}

.panel {
  padding: 32rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.08);
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1f3a;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.type-item {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f4f6fb;
  color: #4a5577;
  font-size: 23rpx;
  transition: all 0.2s;
  text-align: center;
  padding: 0 6rpx;
}

.type-item.active {
  background: linear-gradient(135deg, #5b6cff, #3a4cd1);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(91, 108, 255, 0.25);
}

.field {
  margin-bottom: 22rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  font-size: 25rpx;
  color: #4a5577;
  font-weight: 700;
}

.field input,
.field textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f4f6fb;
  color: #1a1f3a;
  font-size: 27rpx;
  border: 2rpx solid transparent;
}

.field input {
  height: 84rpx;
  padding: 0 22rpx;
}

.field textarea {
  min-height: 240rpx;
  padding: 20rpx 22rpx;
}

.counter {
  margin-top: 8rpx;
  text-align: right;
  font-size: 22rpx !important;
  color: #8a96a8 !important;
  font-weight: 400 !important;
}

.switch-row {
  margin: 12rpx 0 28rpx;
  padding: 24rpx 26rpx;
  border-radius: 14rpx;
  background: #f4f6fb;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.switch-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: #1a1f3a;
}

.switch-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.primary-btn {
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 16rpx !important;
  color: #ffffff !important;
  background: linear-gradient(135deg, #5b6cff, #3a4cd1) !important;
  font-size: 28rpx !important;
  font-weight: 700 !important;
  border: none !important;
  box-shadow: 0 8rpx 20rpx rgba(91, 108, 255, 0.3);
}

.primary-btn::after { border: none !important; }

.feedback-card {
  position: relative;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(91, 108, 255, 0.08);
  overflow: hidden;
}

.feedback-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #5b6cff, #f5b041);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.card-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #9a3412;
  background: #ffedd5;
  font-size: 22rpx;
}

.status.resolved {
  color: #166534;
  background: #dcfce7;
}

.content {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #475569;
  white-space: pre-wrap;
}

.remark {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
}

.remark-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #8a96a8;
}

.remark-text {
  display: block;
  font-size: 25rpx;
  color: #334155;
}

.empty-state {
  padding: 90rpx 32rpx;
  text-align: center;
  color: #7b8794;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #475569;
}

.empty-text {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
}

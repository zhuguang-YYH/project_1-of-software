.theme-gold .btn-cancel,
.theme-gold .btn-cancel-modal,
.theme-gold .form-cancel-btn,
.theme-gold .btn-unavailable {
  color: #d4af37 !important;
  background: rgba(212, 175, 55, 0.10) !important;
  border-color: rgba(212, 175, 55, 0.22) !important;
}

.theme-gold .avatar-edit-badge,
.theme-gold .status-icon {
  background: #d4af37 !important;
}

.theme-gold .user-avatar,
.theme-gold .borrow-cover,
.theme-gold .script-cover,
.theme-gold .podium-avatar {
  background: #222 !important;
  border-color: rgba(212, 175, 55, 0.42) !important;
}

.theme-gold .loading-spinner {
  border-color: rgba(212, 175, 55, 0.16) !important;
  border-top-color: #d4af37 !important;
}

.theme-gold.loading-state {
  min-height: 100vh !important;
  color: #f4ecd6;
  background:
    radial-gradient(circle at 92% 2%, rgba(212, 175, 55, 0.20) 0%, rgba(212, 175, 55, 0.00) 36%),
    radial-gradient(circle at 8% 30%, rgba(212, 175, 55, 0.12) 0%, rgba(212, 175, 55, 0.00) 32%),
    linear-gradient(135deg, #0a0a0a 0%, #161616 48%, #202020 100%) !important;
}

.theme-gold.loading-state .loading-spinner {
  border-color: rgba(212, 175, 55, 0.16) !important;
  border-top-color: #d4af37 !important;
}

.theme-gold.loading-state .loading-text,
.theme-gold .loading-state text,
.theme-gold.loading-state text {
  color: rgba(244, 236, 214, 0.68) !important;
}

.theme-gold .empty-state {
  color: rgba(244, 236, 214, 0.68);
  background: #171717 !important;
  border: 1rpx solid rgba(212, 175, 55, 0.18);
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.24);
}

/* Theme: black gold cross-page hardening */
.theme-gold .activity-details,
.theme-gold .exchange-details,
.theme-gold .modal-section,
.theme-gold .section-value,
.theme-gold .reason-input,
.theme-gold .message-input,
.theme-gold .search-input,
.theme-gold .qty-value,
.theme-gold .answer-status,
.theme-gold .analysis,
.theme-gold .answer-card,
.theme-gold .log-item,
.theme-gold .history-card,
.theme-gold .settings-panel,
.theme-gold .theme-option {
  color: #f4ecd6 !important;
  background: #151515 !important;
  border-color: rgba(212, 175, 55, 0.24) !important;
}

/* setting-row / action-row 继承父级 section 背景，避免出现黑色横条 */
.theme-gold .setting-row,
.theme-gold .action-row {
  background: transparent !important;
  border-color: rgba(212, 175, 55, 0.18) !important;
}

.theme-gold .modal-header,
.theme-gold .modal-head,
.theme-gold .modal-footer,
.theme-gold .composer {
  background: #111111 !important;
  border-color: rgba(212, 175, 55, 0.16) !important;
}

.theme-gold .modal-overlay,
.theme-gold .modal-mask {
  background: rgba(0, 0, 0, 0.66) !important;
}

.theme-gold .card-title,
.theme-gold .empty-title,
.theme-gold .section-label,
.theme-gold .modal-title,
.theme-gold .question-text,
.theme-gold .option-label,
.theme-gold .log-reason,
.theme-gold .setting-title {
  color: #f4ecd6 !important;
}

.theme-gold .reason,
.theme-gold .meta-row,
.theme-gold .modal-meta,
.theme-gold .detail-reason,
.theme-gold .input-hint,
.theme-gold .load-more,
.theme-gold .empty-text,
.theme-gold .setting-value,
.theme-gold .card-desc,
.theme-gold .card-meta,
.theme-gold .log-time,
.theme-gold .history-meta {
  color: rgba(244, 236, 214, 0.68) !important;
}

.theme-gold .detail-value,
.theme-gold .section-value,
.theme-gold .card-section-value {
  color: #f4ecd6 !important;
}

.theme-gold .from-dud .bubble,
.theme-gold .typing-bubble {
  color: #f4ecd6 !important;
  background: rgba(20, 20, 20, 0.96) !important;
  border: 1rpx solid rgba(212, 175, 55, 0.20);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.28);
}

.theme-gold .from-user .bubble,
.theme-gold .send-btn,
.theme-gold .send-btn[disabled],
.theme-gold .search-btn,
.theme-gold .link-btn,
.theme-gold .btn-exchange,
.theme-gold .btn-submit,
.theme-gold .publish-btn {
  color: #17110a !important;
  background: linear-gradient(135deg, #f8e7a8 0%, #d4af37 54%, #b98d1d 100%) !important;
  box-shadow: 0 10rpx 28rpx rgba(212, 175, 55, 0.26) !important;
}

.theme-gold .btn-submit[disabled],
.theme-gold .send-btn[disabled] {
  opacity: 0.72;
}

.theme-gold .prompt,
.theme-gold .category-item,
.theme-gold .icon-btn,
.theme-gold .close-btn,
.theme-gold .modal-close,
.theme-gold .btn-back,
.theme-gold .btn-full,
.theme-gold .btn-confirmed,
.theme-gold .btn-soldout,
.theme-gold .btn-insufficient,
.theme-gold .qty-btn {
  color: #d4af37 !important;
  background: rgba(212, 175, 55, 0.10) !important;
  border-color: rgba(212, 175, 55, 0.22) !important;
  box-shadow: none !important;
}

.theme-gold .category-item.active,
.theme-gold .theme-option.active,
.theme-gold .option-item.selected {
  color: #17110a !important;
  background: linear-gradient(135deg, #f8e7a8 0%, #d4af37 54%, #b98d1d 100%) !important;
  border-color: rgba(212, 175, 55, 0.62) !important;
}

.theme-gold .cover,
.theme-gold .detail-cover,
.theme-gold .empty-cover,
.theme-gold .puzzle-cover {
  color: #d4af37 !important;
  background:
    linear-gradient(135deg, rgba(212, 175, 55, 0.10), rgba(255, 255, 255, 0.02)),
    #151515 !important;
  border: 1rpx solid rgba(212, 175, 55, 0.18);
}

.theme-gold .progress-bar {
  background: rgba(212, 175, 55, 0.16) !important;
}

.theme-gold .progress-fill {
  background: linear-gradient(90deg, #f8e7a8, #d4af37, #b98d1d) !important;
}

.theme-gold .activity-status,
.theme-gold .registration-status,
.theme-gold .badge,
.theme-gold .status-tag {
  color: #17110a !important;
  background: #ead17a !important;
}

.theme-gold .error-banner {
  color: #ffd2d2 !important;
  background: rgba(127, 29, 29, 0.24) !important;
  border-color: rgba(248, 113, 113, 0.42) !important;
}
